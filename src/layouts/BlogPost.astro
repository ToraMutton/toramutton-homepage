---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";
import {
    Twitter,
    Github,
    MessageCircle,
    Share2,
    ExternalLink,
    List,
} from "lucide-astro";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

import {
    TW_DAILY_URL,
    TW_TECH_URL,
    GITHUB_URL,
    NOTE_URL,
    ZENN_URL,
    QIITA_URL,
} from "../consts";

type Props = CollectionEntry<"blog">["data"] & {
    headings?: MarkdownHeading[];
};

const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    tags = [],
    headings = [],
} = Astro.props;

const shareUrl = Astro.url.href;
const shareText = `${title} | トラマト`;
const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`;
---

<html lang="ja">
    <head>
        <BaseHead title={title} description={description} image={heroImage} />
        <style>
            :global(html) {
                scroll-behavior: smooth;
            }

            main {
                width: 100%;
                max-width: 100%;
                margin: 0 auto;
                padding-top: 80px;
            }

            /* === ヒーロー画像 === */
            .hero-image {
                width: 100%;
                margin: 0;
                padding: 0;
            }
            .hero-image:empty {
                display: none;
            }
            .hero-image img {
                display: block;
                width: 100%;
                height: auto;
                border-radius: var(--radius);
                object-fit: cover;
            }
            @media (min-width: 1280px) {
                .hero-image {
                    width: calc(100% + 3rem);
                    margin: -1.5rem -1.5rem 2rem;
                }
                .hero-image img {
                    border-bottom-left-radius: 0;
                    border-bottom-right-radius: 0;
                }
            }

            /* === 本文 === */
            .prose {
                width: 100%;
                max-width: 860px;
                padding: 1rem 0;
                color: var(--text-main);
                line-height: 1.8;
            }

            .title {
                margin-bottom: 2rem;
                padding: 0;
                display: flex;
                flex-direction: column;
                align-items: center;
                text-align: center;
            }
            .title h1 {
                font-size: 2.5rem;
                margin: 0 0 0.5em 0;
                color: var(--text-main);
                font-weight: 800;
                letter-spacing: -0.02em;
            }

            .date {
                display: flex;
                flex-direction: column;
                align-items: center;
                margin-bottom: 1rem;
                color: var(--text-muted);
                font-weight: 500;
            }
            .last-updated-on {
                font-style: italic;
                font-size: 0.9rem;
                opacity: 0.8;
            }

            /* === 本文内タグ === */
            .prose :global(h2) {
                font-size: 1.8rem;
                margin: 3rem 0 1.5rem;
                padding-bottom: 0.5rem;
                border-bottom: 2px solid var(--accent-blue);
                color: var(--text-main);
            }
            .prose :global(p) {
                margin-bottom: 1.5rem;
            }

            /* 引用ブロック（角丸・影撤去 → 左ボーダーのみ） */
            .prose :global(blockquote) {
                margin: 2rem 0;
                padding: 1.5rem 2rem;
                background: var(--surface);
                border-left: 3px solid var(--accent-blue);
                border-radius: 0;
                font-style: italic;
                color: var(--text-muted);
            }

            /* コードブロック（影撤去・4px・border 化） */
            .prose :global(pre) {
                padding: 1.5rem;
                border-radius: var(--radius);
                border: 1px solid var(--border-color);
                margin: 2rem 0;
                font-family: var(--font-mono);
                font-size: 0.95rem;
                overflow-x: auto;
            }

            @media (max-width: 720px) {
                .prose {
                    padding: 1rem;
                }
                .title h1 {
                    font-size: 1.8rem;
                }
                .blog-toc {
                    width: min(300px, 42vw);
                }
            }

            /* === モバイル用シェアボタン（ターミナル化）=== */
            .mobile-share-container {
                display: flex;
                justify-content: center;
                margin-top: 3rem;
                padding-top: 2rem;
                border-top: 1px dashed var(--border-color);
            }
            .mobile-share-btn {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                width: 100%;
                max-width: 280px;
                padding: 0.8rem;
                border-radius: var(--radius);
                background: color-mix(
                    in srgb,
                    var(--accent-blue) 8%,
                    transparent
                );
                border: 1px solid
                    color-mix(in srgb, var(--accent-blue) 25%, transparent);
                color: var(--accent-blue);
                text-decoration: none;
                font-size: 0.9rem;
                font-weight: 600;
                transition:
                    background 0.2s,
                    color 0.2s,
                    border-color 0.2s;
            }
            .mobile-share-btn:hover {
                background: var(--accent-blue);
                color: var(--background);
                border-color: var(--accent-blue);
            }
            @media (min-width: 1280px) {
                .mobile-share-container {
                    display: none;
                }
            }

            /* === タグ === */
            .tags-container {
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                justify-content: center;
                margin-top: 1rem;
            }
            .tag {
                background: color-mix(
                    in srgb,
                    var(--accent-blue) 10%,
                    transparent
                );
                color: var(--accent-blue);
                border: 1px solid
                    color-mix(in srgb, var(--accent-blue) 25%, transparent);
                padding: 0.2rem 0.8rem;
                border-radius: var(--radius);
                font-size: 0.85rem;
                font-weight: 600;
                font-family: var(--font-mono);
            }

            /* === テーブル === */
            .prose :global(table) {
                width: 100%;
                border-collapse: collapse;
                margin: 2rem 0;
                font-size: 0.9rem;
            }
            .prose :global(th),
            .prose :global(td) {
                border: 1px solid var(--border-color);
                padding: 0.8rem;
                text-align: center;
            }
            .prose :global(th) {
                background: var(--elevated);
                font-weight: bold;
                color: var(--text-main);
            }
            .prose :global(tr:nth-child(even)) {
                background: color-mix(
                    in srgb,
                    var(--text-main) 3%,
                    transparent
                );
            }

            /* ======================================================
       3カラム レイアウト
       ====================================================== */
            .blog-container {
                display: grid;
                grid-template-columns: 1fr;
                gap: 2rem;
                width: 100%;
                max-width: 860px;
                margin: 0 auto;
                padding: 0;
                align-items: flex-start;
            }

            article {
                width: 100%;
                min-width: 0;
                margin: 0;
            }
            @media (min-width: 1280px) {
                article {
                    background: var(--surface);
                    border: 1px solid var(--border-color);
                    border-radius: var(--radius);
                    padding: 1.5rem 1.5rem 1rem;
                }
            }

            .blog-main-content {
                width: 100%;
            }

            /* ① 左サイドバーはPCのみ（モバイル・タブレットでは非表示）*/
            .blog-sidebar-left {
                display: none;
            }
            .blog-toc {
                display: none;
            }

            @media (min-width: 1280px) {
                .blog-container {
                    max-width: 1360px;
                    grid-template-columns: 260px minmax(0, 860px) 240px;
                    justify-content: center;
                    padding: 0 2rem;
                }
                .blog-sidebar-left,
                .blog-toc {
                    display: block;
                    position: sticky;
                    top: 6rem;
                    max-height: calc(100vh - 8rem);
                    overflow-y: auto;
                    margin: 0;
                }
            }

            /* ======================================================
       左サイドバー - プロフィール & SNS（border-card 化）
       ====================================================== */
            .sidebar-card {
                background: var(--surface);
                border: 1px solid var(--border-color);
                border-radius: var(--radius);
                padding: 1.5rem 1.2rem;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 1.2rem;
            }

            .sidebar-avatar {
                width: 80px;
                height: 80px;
                border-radius: var(--radius); /* 50% → 4px */
                object-fit: cover;
                border: 1px solid var(--border-color);
            }

            .sidebar-name {
                font-size: 1.1rem;
                font-weight: 800;
                color: var(--text-main);
                margin: 0;
            }
            .sidebar-bio {
                font-size: 0.8rem;
                color: var(--text-muted);
                text-align: center;
                line-height: 1.5;
                margin: 0;
            }
            .sidebar-divider {
                width: 100%;
                height: 1px;
                background: var(--border-color);
                margin: 0.2rem 0;
            }

            .sidebar-section-title {
                font-size: 0.75rem;
                font-weight: 700;
                color: var(--text-muted);
                text-transform: uppercase;
                letter-spacing: 0.08em;
                align-self: flex-start;
                margin: 0;
                font-family: var(--font-mono);
            }

            .sidebar-sns-list {
                display: flex;
                flex-direction: column;
                gap: 0.15rem;
                width: 100%;
            }
            .sidebar-sns-link {
                display: flex;
                align-items: center;
                gap: 0.7rem;
                padding: 0.45rem 0.6rem;
                border-radius: var(--radius);
                color: var(--text-muted);
                text-decoration: none;
                font-size: 0.82rem;
                font-weight: 500;
                transition:
                    background 0.2s,
                    color 0.2s,
                    transform 0.2s;
            }
            .sidebar-sns-link:hover {
                background: color-mix(
                    in srgb,
                    var(--text-main) 6%,
                    transparent
                );
                color: var(--text-main);
                transform: translateX(2px);
            }

            .sidebar-sns-link .sns-icon {
                display: flex;
                align-items: center;
                justify-content: center;
                width: 28px;
                height: 28px;
                border-radius: var(--radius); /* 8px → 4px */
                flex-shrink: 0;
                transition:
                    background 0.2s,
                    color 0.2s;
            }

            /* ブランドカラー ホバー（per-source アクセントは維持）*/
            .sidebar-sns-link[data-brand="twitter"]:hover .sns-icon {
                background: #1da1f2;
                color: white;
            }
            .sidebar-sns-link[data-brand="tech"]:hover .sns-icon {
                background: #f59518;
                color: white;
            }
            .sidebar-sns-link[data-brand="github"]:hover .sns-icon {
                background: #333;
                color: white;
            }
            :global(html.dark)
                .sidebar-sns-link[data-brand="github"]:hover
                .sns-icon {
                background: #f0f0f0;
                color: #333;
            }
            .sidebar-sns-link[data-brand="note"]:hover .sns-icon {
                background: #41c9b4;
                color: white;
            }
            .sidebar-sns-link[data-brand="zenn"]:hover .sns-icon {
                background: #3ea8ff;
                color: white;
            }
            .sidebar-sns-link[data-brand="qiita"]:hover .sns-icon {
                background: #55c500;
                color: white;
            }

            .sns-label {
                flex: 1;
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            /* シェアボタン（ターミナル化）*/
            .sidebar-share-link {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                width: 100%;
                padding: 0.6rem;
                border-radius: var(--radius);
                background: color-mix(
                    in srgb,
                    var(--accent-blue) 8%,
                    transparent
                );
                border: 1px solid
                    color-mix(in srgb, var(--accent-blue) 25%, transparent);
                color: var(--accent-blue);
                text-decoration: none;
                font-size: 0.82rem;
                font-weight: 600;
                transition:
                    background 0.2s,
                    color 0.2s,
                    border-color 0.2s;
            }
            .sidebar-share-link:hover {
                background: var(--accent-blue);
                color: var(--background);
                border-color: var(--accent-blue);
            }

            /* ======================================================
       右サイドバー - 目次（② カード撤去 → 余白一重）
       ====================================================== */
            .toc-card {
                position: relative;
                padding-top: 0.5rem; /* progress バー分の余白のみ */
            }

            /* 読了プログレスバー（gradient → solid / 角丸撤去 / 2px）*/
            .toc-progress {
                position: absolute;
                top: 0;
                left: 0;
                height: 2px;
                width: 0%;
                background: var(--accent-blue);
                transition: width 0.15s ease-out;
                z-index: 1;
            }

            .toc-title {
                font-weight: 800;
                font-size: 0.95rem;
                margin-bottom: 0.8rem;
                color: var(--text-main);
                border-bottom: 1px solid var(--border-color);
                padding-bottom: 0.5rem;
                display: flex;
                align-items: center;
                gap: 0.4rem;
            }
            .toc-title-icon {
                display: flex;
                align-items: center;
                color: var(--accent-blue);
            }

            .toc-card ul {
                list-style: none;
                padding: 0;
                margin: 0;
            }
            .toc-card li {
                margin-bottom: 0.15rem;
                line-height: 1.3;
            }
            .toc-card a {
                text-decoration: none;
                color: var(--text-muted);
                font-size: 0.82rem;
                display: block;
                padding: 0.3rem 0.5rem;
                border-radius: 0; /* 角丸撤去 */
                transition:
                    background 0.2s,
                    color 0.2s;
                border-left: 2px solid transparent;
            }
            .toc-card a:hover {
                color: var(--accent-blue);
                background: color-mix(
                    in srgb,
                    var(--accent-blue) 6%,
                    transparent
                );
            }
            .toc-card a.active {
                color: var(--accent-blue);
                font-weight: 700;
                border-left-color: var(--accent-blue);
                background: color-mix(
                    in srgb,
                    var(--accent-blue) 8%,
                    transparent
                );
            }

            /* === h3 ツリーライン === */
            .toc-level-3 {
                padding-left: 0;
                position: relative;
            }
            /* 縦線：各 li が自分の高さ分だけ引く → 積み上がって1本に見える */
            .toc-level-3::before {
                content: "";
                position: absolute;
                left: 0.55rem;
                top: 0;
                bottom: 0;
                width: 1px;
                background: var(--border-color);
            }
            /* グループ末尾だけ縦線を上半分に切る（└── 表現）*/
            .toc-level-3:last-child::before,
            .toc-level-3:has(+ .toc-level-2)::before {
                bottom: 50%;
            }
            /* 横ブランチ */
            .toc-level-3 > a {
                font-size: 0.8rem;
                border-left: none; /* 縦線と競合するため削除 */
                padding-left: 1.6rem;
                position: relative;
            }
            .toc-level-3 > a::before {
                content: "";
                position: absolute;
                left: 0.55rem;
                top: 50%;
                transform: translateY(-50%);
                width: 0.65rem;
                height: 1px;
                background: var(--border-color);
                transition: background 0.2s;
            }
            /* アクティブ時：横ブランチも accent に */
            .toc-level-3 > a.active {
                border-left: none;
            }
            .toc-level-3 > a.active::before {
                background: var(--accent-blue);
            }

            /* === h4 ツリーライン（h3 より右に入れ子）=== */
            .toc-level-4 {
                padding-left: 0.8rem;
                position: relative;
            }
            .toc-level-4::before {
                content: "";
                position: absolute;
                left: 0.55rem;
                top: 0;
                bottom: 0;
                width: 1px;
                background: var(--border-color);
            }
            /* h4 グループ末尾（次が h4 以外、またはリスト最後）で縦線カット */
            .toc-level-4:last-child::before,
            .toc-level-4:has(+ :not(.toc-level-4))::before {
                bottom: 50%;
            }
            .toc-level-4 > a {
                font-size: 0.78rem;
                border-left: none;
                padding-left: 1.6rem;
                position: relative;
                opacity: 0.85;
            }
            .toc-level-4 > a::before {
                content: "";
                position: absolute;
                left: 0.55rem;
                top: 50%;
                transform: translateY(-50%);
                width: 0.65rem;
                height: 1px;
                background: var(--border-color);
                transition: background 0.2s;
            }
            .toc-level-4 > a.active {
                border-left: none;
                opacity: 1;
            }
            .toc-level-4 > a.active::before {
                background: var(--accent-blue);
            }

            /* --- TOC: Zenn 風サイドドロワー（≤1279px / 右側維持）--- */
            @media (max-width: 1279px) {
                .blog-toc {
                    display: block;
                    position: fixed;
                    top: var(--header-height, 64px);
                    right: 0;
                    width: min(300px, 42vw);
                    height: calc(100dvh - var(--header-height, 64px));
                    overflow-y: auto;
                    z-index: 1000;

                    background: var(--surface);
                    border-left: 1px solid var(--border-color);
                    padding: 1.5rem 1.25rem;

                    opacity: 0;
                    transform: translateX(16px);
                    pointer-events: none;
                    visibility: hidden;

                    transition:
                        opacity 0.18s ease-out,
                        transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
                        visibility 0s linear 0.22s;
                }
                .blog-toc.mobile-open {
                    opacity: 1;
                    transform: translateX(0);
                    pointer-events: auto;
                    visibility: visible;
                    transition:
                        opacity 0.18s ease-out,
                        transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
                        visibility 0s linear 0s;
                }
                @media (prefers-reduced-motion: reduce) {
                    .blog-toc,
                    .blog-toc.mobile-open {
                        transition: none;
                    }
                }
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <div class="blog-container">
                {/* 左サイドバー - プロフィール & SNS */}
                <aside class="blog-sidebar-left">
                    <div class="sidebar-card">
                        <img
                            src="/toramutton.jpg"
                            alt="トラマト"
                            class="sidebar-avatar"
                            width="80"
                            height="80"
                        />
                        <p class="sidebar-name">トラマト</p>
                        <p class="sidebar-bio">勉強中</p>

                        <div class="sidebar-divider"></div>

                        <p class="sidebar-section-title">SNS</p>
                        <nav class="sidebar-sns-list">
                            <a
                                href={TW_DAILY_URL}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="sidebar-sns-link"
                                data-brand="twitter"
                            >
                                <span class="sns-icon"
                                    ><MessageCircle size={16} /></span
                                >
                                <span class="sns-label">Daily</span>
                            </a>
                            <a
                                href={TW_TECH_URL}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="sidebar-sns-link"
                                data-brand="tech"
                            >
                                <span class="sns-icon"
                                    ><Twitter size={16} /></span
                                >
                                <span class="sns-label">Tech</span>
                            </a>
                            <a
                                href={GITHUB_URL}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="sidebar-sns-link"
                                data-brand="github"
                            >
                                <span class="sns-icon"
                                    ><Github size={16} /></span
                                >
                                <span class="sns-label">GitHub</span>
                            </a>
                            <a
                                href={NOTE_URL}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="sidebar-sns-link"
                                data-brand="note"
                            >
                                <span class="sns-icon">
                                    <svg
                                        role="img"
                                        viewBox="0 0 24 24"
                                        width="14"
                                        height="14"
                                        fill="currentColor"
                                    >
                                        <path
                                            d="M0 .279c4.623 0 10.953-.235 15.498-.117 6.099.156 8.39 2.813 8.468 9.374.077 3.71 0 14.335 0 14.335h-6.598c0-9.296.04-10.83 0-13.759-.078-2.578-.814-3.807-2.795-4.041-2.097-.235-7.975-.04-7.975-.04v17.84H0Z"
                                        ></path>
                                    </svg>
                                </span>
                                <span class="sns-label">note</span>
                            </a>
                            <a
                                href={ZENN_URL}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="sidebar-sns-link"
                                data-brand="zenn"
                            >
                                <span class="sns-icon">
                                    <svg
                                        role="img"
                                        viewBox="0 0 24 24"
                                        width="16"
                                        height="16"
                                        fill="currentColor"
                                    >
                                        <path
                                            d="M.264 23.771h4.984c.264 0 .498-.147.645-.352L19.614.874c.176-.293-.029-.645-.381-.645h-4.72c-.235 0-.44.117-.557.323L.03 23.361c-.088.176.029.41.234.41zM17.445 23.419l6.479-10.408c.205-.323-.029-.733-.41-.733h-4.691c-.176 0-.352.088-.44.235l-6.655 10.643c-.176.264.029.616.352.616h4.779c.234-.001.468-.118.586-.353z"
                                        ></path>
                                    </svg>
                                </span>
                                <span class="sns-label">Zenn</span>
                            </a>
                            <a
                                href={QIITA_URL}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="sidebar-sns-link"
                                data-brand="qiita"
                            >
                                <span class="sns-icon">
                                    <svg
                                        role="img"
                                        viewBox="0 0 24 24"
                                        width="16"
                                        height="16"
                                        fill="currentColor"
                                    >
                                        <path
                                            d="M12 0C5.3726 0 0 5.3726 0 12s5.3726 12 12 12c3.3984 0 6.4665-1.413 8.6498-3.6832-.383-.0574-.7746-.2062-1.1466-.4542-.7145-.4763-1.3486-.9263-1.6817-1.674-1.2945 1.3807-3.0532 1.835-5.1822 2.0503-4.311.4359-8.0456-1.4893-8.4979-6.2996-.1922-2.045.2628-3.989 1.1804-5.582l-.5342-2.1009c-.0862-.3652.2498-.7126.6057-.6262l1.8456.448c1.0974-.9012 2.4249-1.49 3.8892-1.638 1.2526-.1267 2.467.0834 3.571.5624l1.7348-1.0494c.3265-.1974.7399.0257.7711.4164l.1 2.4747v.0002c1.334 1.4084 2.2424 3.3319 2.4478 5.516.116 1.2339-.012 2.1776-.339 3.078-.1531.4215-.1992.7778.0776 1.1305.2674.3408.6915 1.0026 1.1644.8917.7107-.1666 1.4718-.1223 1.9422.1715C23.4925 15.9525 24 14.0358 24 12c0-6.6274-5.3726-12-12-12Zm-.0727 5.727a5.2731 5.2731 0 0 0-.6146.0273c-2.2084.2233-3.9572 1.8135-4.4937 3.8484l-1.3176-.1996-.014.2589 1.2972.1407c-.0352.1497-.0643.2384-.086.3923l-1.1319.0902.0103.2025 1.1032-.088c-.0194.1713-.031.2814-.0332.4565l-1.0078.412.0495.2499.9598-.4492c.002.1339.008.2053.0207.3407.2667 2.8371 2.6364 3.3981 5.4677 3.1118 2.8312-.2863 5.0517-1.3114 4.785-4.1486-.013-.1361-.0324-.2068-.0553-.3392l1.0397.2257.0242-.229-1.0906-.207c-.0342-.1687-.0765-.271-.1264-.4327l1.1208-.1374-.0158-.2019-1.1499.1409a5.1093 5.1093 0 0 0-.1665-.4259l1.2665-.4042-.0397-.2536-1.3471.4667c-.819-1.7168-2.5002-2.8224-4.4546-2.8482Z"
                                        ></path>
                                    </svg>
                                </span>
                                <span class="sns-label">Qiita</span>
                            </a>
                        </nav>

                        <div class="sidebar-divider"></div>

                        <p class="sidebar-section-title">Share</p>
                        <a
                            href={twitterShareUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="sidebar-share-link"
                        >
                            <Share2 size={14} />
                            Twitterでシェア
                        </a>
                    </div>
                </aside>

                <article>
                    {
                        heroImage && (
                            <div class="hero-image">
                                <Image
                                    width={1020}
                                    height={510}
                                    src={heroImage}
                                    alt={title}
                                />
                            </div>
                        )
                    }
                    <div class="prose">
                        <div class="title">
                            <div class="date">
                                <FormattedDate date={pubDate} />
                                {
                                    updatedDate && (
                                        <div class="last-updated-on">
                                            Last updated on{" "}
                                            <FormattedDate date={updatedDate} />
                                        </div>
                                    )
                                }
                            </div>
                            <h1>{title}</h1>
                        </div>
                        <slot />

                        {/* モバイル用シェアボタン (PCでは非表示) */}
                        <div class="mobile-share-container">
                            <a
                                href={twitterShareUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="mobile-share-btn"
                            >
                                <Share2 size={16} />
                                Twitterでシェア
                            </a>
                        </div>
                    </div>
                </article>

                {/* 右サイド - 目次 */}
                {
                    headings.length > 0 && (
                        <aside class="blog-toc">
                            <div class="toc-card">
                                <div class="toc-progress" id="toc-progress" />
                                <div class="toc-title">
                                    <span class="toc-title-icon">
                                        <List size={16} />
                                    </span>
                                    目次
                                </div>
                                <ul>
                                    {headings.map((heading) => (
                                        <li
                                            class={`toc-level-${heading.depth}`}
                                        >
                                            <a href={`#${heading.slug}`}>
                                                {heading.text}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </aside>
                    )
                }
            </div>
        </main>
        <Footer />
    </body>
</html>

<script>
    // === h2 アニメーション ===
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                }
            });
        },
        { threshold: 0.5 },
    );

    document.querySelectorAll("article h2").forEach((h2) => {
        observer.observe(h2);
    });

    // === モバイル用目次のリンククリック時に閉じる ===
    const tocSidebarMobile = document.querySelector(".blog-toc");
    const tocToggleBtn = document.getElementById("toc-toggle");
    document.querySelectorAll(".blog-toc a").forEach((link) => {
        link.addEventListener("click", () => {
            if (
                window.innerWidth < 1280 &&
                tocSidebarMobile &&
                tocSidebarMobile.classList.contains("mobile-open")
            ) {
                tocSidebarMobile.classList.remove("mobile-open");
                if (tocToggleBtn) tocToggleBtn.classList.remove("active");
            }
        });
    });

    // === 目次アクティブ追従 ===
    const tocLinks = document.querySelectorAll(".blog-toc a");
    const headings = document.querySelectorAll(
        ".prose h2, .prose h3, .prose h4",
    );

    if (tocLinks.length > 0 && headings.length > 0) {
        const tocObserver = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        const id = entry.target.id;
                        if (!id) return;

                        tocLinks.forEach((link) =>
                            link.classList.remove("active"),
                        );

                        const activeLink = Array.from(tocLinks).find((link) => {
                            const href = link.getAttribute("href");
                            return (
                                href === `#${id}` ||
                                href === `#${encodeURIComponent(id)}` ||
                                href === `#${decodeURIComponent(id)}`
                            );
                        });

                        if (activeLink) {
                            activeLink.classList.add("active");
                        }
                    }
                });
            },
            {
                rootMargin: "-100px 0px -70% 0px",
            },
        );

        headings.forEach((h) => tocObserver.observe(h));
    }

    // === 読了プログレスバー ===
    const progressBar = document.getElementById("toc-progress");
    if (progressBar) {
        window.addEventListener(
            "scroll",
            () => {
                const article = document.querySelector("article");
                if (!article) return;

                const articleTop = article.offsetTop;
                const articleHeight = article.scrollHeight;
                const windowHeight = window.innerHeight;
                const scrollTop = window.scrollY;

                const progress = Math.min(
                    100,
                    Math.max(
                        0,
                        ((scrollTop - articleTop + windowHeight * 0.3) /
                            articleHeight) *
                            100,
                    ),
                );

                progressBar.style.width = `${progress}%`;
            },
            { passive: true },
        );
    }
</script>
