---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";

import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"] & {
    headings?: MarkdownHeading[];
};

const { title, description, pubDate, updatedDate, heroImage, tags = [], headings = [] } = Astro.props;
---

<html lang="ja">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            :global(html) {
                scroll-behavior: smooth;
            }

            main {
                width: 100%;
                max-width: 100vw;
                margin: 0;
                padding-top: 2rem;
            }

            .hero-image {
                width: 100%;
                max-width: 900px;
                margin: 0 auto 2rem;
                padding: 0 1rem;
            }

            .hero-image img {
                display: block;
                width: 100%;
                height: auto;
                border-radius: 20px;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
                object-fit: cover;
            }

            .prose {
                width: 100%;
                max-width: 800px;
                margin: auto;
                padding: 1rem 2rem;
                color: var(--text-main);
                line-height: 1.8;
            }

            .title {
                margin-bottom: 3rem;
                padding: 2rem 0;
                text-align: center;
            }

            .title h1 {
                font-size: 2.5rem;
                margin: 0 0 0.5em 0;
                color: var(--text-main);
                font-weight: 800;
                letter-spacing: -0.02em;
            }

            .date {
                margin-bottom: 1rem;
                color: var(--text-muted);
                font-weight: 500;
            }

            .last-updated-on {
                font-style: italic;
                font-size: 0.9rem;
                opacity: 0.8;
            }

            /* === 本文内タグ === */
            
            .prose :global(h2) {
                font-size: 1.8rem;
                margin: 3rem 0 1.5rem;
                padding-bottom: 0.5rem;
                border-bottom: 2px solid var(--accent-blue);
                color: var(--text-main);
            }

            .prose :global(p) {
                margin-bottom: 1.5rem;
            }

            /* 引用ブロック */
            .prose :global(blockquote) {
                margin: 2rem 0;
                padding: 1.5rem 2rem;
                background: rgba(125, 211, 252, 0.05);
                border-left: 4px solid var(--accent-blue);
                border-radius: 0 12px 12px 0;
                font-style: italic;
                color: var(--text-muted);
            }

            /* コードブロック */
            .prose :global(pre) {
                padding: 1.5rem;
                border-radius: 12px;
                margin: 2rem 0;
                font-family: 'Fira Code', 'Cascadia Code', monospace;
                font-size: 0.95rem;
                overflow-x: auto;
                box-shadow: inset 0 0 10px rgba(0,0,0,0.2);
            }

            /* ダークモード時の調整 */
            :global(html.dark) .hero-image img {
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
            }

            @media (max-width: 720px) {
                .prose {
                    padding: 1rem;
                }
                .title h1 {
                    font-size: 1.8rem;
                }
            }

            .tags-container {
                display: flex;
                flex-wrap: wrap;
                gap: 0.5rem;
                justify-content: center;
                margin-top: 1rem;
            }

            .tag {
                background: rgba(2, 132, 199, 0.1);
                color: var(--accent-blue);
                border: 1px solid rgba(2, 132, 199, 0.2);
                padding: 0.2rem 0.8rem;
                border-radius: 99px;
                font-size: 0.85rem;
                font-weight: 600;
                font-family: 'JetBrains Mono', monospace;
            }

            :global(html.dark) .tag {
                background: rgba(125, 211, 252, 0.1);
                border-color: rgba(125, 211, 252, 0.3);
            }

            .prose :global(table) {
                width: 100%;
                border-collapse: collapse; 
                margin: 2rem 0;
                font-size: 0.9rem;
            }

            /* ライトモード */
            .prose :global(th), .prose :global(td) {
                border: 1px solid var(--border-color); 
                padding: 0.8rem;
                text-align: center;
            }

            .prose :global(th) {
                background: rgba(0, 0, 0, 0.05); 
                font-weight: bold;
                color: var(--text-main); 
            }

            /* ダークモード */
            :global(html.dark) .prose :global(th) {
                background: rgba(255, 255, 255, 0.1);
                color: #ffffff;
            }

            :global(html.dark) .prose :global(th), 
            :global(html.dark) .prose :global(td) {
                border-color: rgba(255, 255, 255, 0.2);
            }

            .prose :global(tr:nth-child(even)) {
                background: rgba(255, 255, 255, 0.02);
            }

            /* === 目次レイアウト === */
            .blog-container {
                display: flex;
                gap: 2rem;
                max-width: 1200px;
                margin: 0 auto;
                padding: 0 1rem;
            }

            .blog-main-content {
                flex: 1;
                min-width: 0; /* 画像のはみ出し防止 */
            }

            .blog-toc {
                display: none;
                width: 260px;
                flex-shrink: 0;
            }

            @media (min-width: 1024px) {
                .blog-toc {
                    display: block;
                }
                .toc-sticky {
                    position: sticky;
                    top: 100px;
                    max-height: calc(100vh - 120px);
                    overflow-y: auto;
                    padding: 1.5rem;
                    background: var(--surface);
                    border: 1px solid var(--border-color);
                    border-radius: 12px;
                }
            }

            /* === 目次の中身の装飾 === */
            .toc-title {
                font-weight: 800;
                font-size: 1.1rem;
                margin-bottom: 1rem;
                color: var(--text-main);
                border-bottom: 2px solid var(--border-color);
                padding-bottom: 0.5rem;
            }

            .toc-sticky ul {
                list-style: none;
                padding: 0;
                margin: 0;
            }

            .toc-sticky li {
                margin-bottom: 0.6rem;
                line-height: 1.4;
            }

            .toc-sticky a {
                text-decoration: none;
                color: var(--text-muted);
                font-size: 0.9rem;
                display: block;
                transition: color 0.2s;
            }

            .toc-sticky a:hover {
                color: var(--accent-blue);
            }

            .toc-sticky a.active {
                color: var(--accent-blue);
                font-weight: bold;
                position: relative;
            }

            .toc-sticky a.active::before {
                content: "";
                position: absolute;
                left: -12px;
                top: 2px;
                bottom: 2px;
                width: 3px;
                background-color: var(--accent-blue);
                border-radius: 2px;
            }

            .toc-level-3 {
                padding-left: 1rem;
                font-size: 0.85rem;
            }

            .toc-level-4 {
                padding-left: 1.8rem;
                font-size: 0.8rem;
                opacity: 0.8;
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <div class="blog-container">

                <article>
                    <div class="hero-image">
                        {
                            heroImage && (
                                <Image
                                    width={1020}
                                    height={510}
                                    src={heroImage}
                                    alt={title}
                                />
                            )
                        }
                    </div>
                    <div class="prose">
                        <div class="title">
                            <div class="date">
                                <FormattedDate date={pubDate} />
                                {
                                    updatedDate && (
                                        <div class="last-updated-on">
                                            Last updated on{" "}
                                            <FormattedDate date={updatedDate} />
                                        </div>
                                    )
                                }
                            </div>
                            <h1>{title}</h1>
                        </div>
                        <slot />
                    </div>
                </article>

                {/* サイド目次 */}
                {headings.length > 0 && (
                    <aside class="blog-toc">
                        <div class="toc-sticky">
                            <div class="toc-title">目次</div>
                            <ul>
                                {headings.map((heading) => (
                                    <li class={`toc-level-${heading.depth}`}>
                                        <a href={`#${heading.slug}`}>{heading.text}</a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </aside>
                )}

            </div>
        </main>
        <Footer />
    </body>
</html>

<script>
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, { threshold: 0.5 });

    document.querySelectorAll('article h2').forEach((h2) => {
        observer.observe(h2);
    });

    const tocLinks = document.querySelectorAll('.blog-toc a');
    const headings = document.querySelectorAll('.prose h2, .prose h3, .prose h4');

    if (tocLinks.length > 0 && headings.length > 0) {
        const tocObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const id = entry.target.id;
                    if (!id) return;

                    tocLinks.forEach(link => link.classList.remove('active'));

                    const activeLink = Array.from(tocLinks).find(link => {
                        const href = link.getAttribute('href');
                        return href === `#${id}` || 
                               href === `#${encodeURIComponent(id)}` || 
                               href === `#${decodeURIComponent(id)}`;
                    });

                    if (activeLink) {
                        activeLink.classList.add('active');
                    }
                }
            });
        }, {
            rootMargin: "-100px 0px -70% 0px"
        });

        headings.forEach(h => tocObserver.observe(h));
    }
</script>
