---
import { Twitter, Github } from "lucide-astro";
import {
    GITHUB_URL,
    TW_DAILY_URL,
    NOTE_URL,
    ZENN_URL,
    QIITA_URL,
} from "../consts";

const year = new Date().getFullYear();
---

<footer>
    <!-- 背景: Arch Linux ロゴ (ASCIIアート) -->
    <pre
        class="footer-bg"
        aria-hidden="true">                  -`
                 .o+`
                `ooo/
               `+oooo:
              `+oooooo:
              -+oooooo+:
            `/:-:++oooo+:
           `/++++/+++++++:
          `/++++++++++++++:
         `/+++ooooooooooooo/`
        ./ooosssso++osssssso+`
       .oossssso-````/ossssss+`
      -osssssso.      :ssssssso.
     :osssssss/        osssso+++.
    /ossssssss/        +ssssooo/-
  `/ossssso+/:-        -:/+osssso+-
 `+sso+:-`                 `.-/+oso:
`++:.                           `-/+/
.`                                 `</pre>

    <div class="footer-main">
        <!-- SNS リンク -->
        <nav class="social-links" aria-label="SNS links">
            <a
                href={TW_DAILY_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link"
            >
                <Twitter size={16} />
                <span>Twitter</span>
            </a>

            <a
                href={GITHUB_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link"
            >
                <Github size={16} />
                <span>GitHub</span>
            </a>

            <a
                href={NOTE_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link"
            >
                <svg
                    role="img"
                    viewBox="0 0 24 24"
                    width="14"
                    height="14"
                    fill="currentColor"
                >
                    <path
                        d="M0 .279c4.623 0 10.953-.235 15.498-.117 6.099.156 8.39 2.813 8.468 9.374.077 3.71 0 14.335 0 14.335h-6.598c0-9.296.04-10.83 0-13.759-.078-2.578-.814-3.807-2.795-4.041-2.097-.235-7.975-.04-7.975-.04v17.84H0Z"
                    ></path>
                </svg>
                <span>note</span>
            </a>

            <a
                href={ZENN_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link"
            >
                <svg
                    role="img"
                    viewBox="0 0 24 24"
                    width="16"
                    height="16"
                    fill="currentColor"
                >
                    <path
                        d="M.264 23.771h4.984c.264 0 .498-.147.645-.352L19.614.874c.176-.293-.029-.645-.381-.645h-4.72c-.235 0-.44.117-.557.323L.03 23.361c-.088.176.029.41.234.41zM17.445 23.419l6.479-10.408c.205-.323-.029-.733-.41-.733h-4.691c-.176 0-.352.088-.44.235l-6.655 10.643c-.176.264.029.616.352.616h4.779c.234-.001.468-.118.586-.353z"
                    ></path>
                </svg>
                <span>Zenn</span>
            </a>

            <a
                href={QIITA_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link"
            >
                <svg
                    role="img"
                    viewBox="0 0 24 24"
                    width="16"
                    height="16"
                    fill="currentColor"
                >
                    <path
                        d="M12 0C5.3726 0 0 5.3726 0 12s5.3726 12 12 12c3.3984 0 6.4665-1.413 8.6498-3.6832-.383-.0574-.7746-.2062-1.1466-.4542-.7145-.4763-1.3486-.9263-1.6817-1.674-1.2945 1.3807-3.0532 1.835-5.1822 2.0503-4.311.4359-8.0456-1.4893-8.4979-6.2996-.1922-2.045.2628-3.989 1.1804-5.582l-.5342-2.1009c-.0862-.3652.2498-.7126.6057-.6262l1.8456.448c1.0974-.9012 2.4249-1.49 3.8892-1.638 1.2526-.1267 2.467.0834 3.571.5624l1.7348-1.0494c.3265-.1974.7399.0257.7711.4164l.1 2.4747v.0002c1.334 1.4084 2.2424 3.3319 2.4478 5.516.116 1.2339-.012 2.1776-.339 3.078-.1531.4215-.1992.7778.0776 1.1305.2674.3408.6915 1.0026 1.1644.8917.7107-.1666 1.4718-.1223 1.9422.1715C23.4925 15.9525 24 14.0358 24 12c0-6.6274-5.3726-12-12-12Zm-.0727 5.727a5.2731 5.2731 0 0 0-.6146.0273c-2.2084.2233-3.9572 1.8135-4.4937 3.8484l-1.3176-.1996-.014.2589 1.2972.1407c-.0352.1497-.0643.2384-.086.3923l-1.1319.0902.0103.2025 1.1032-.088c-.0194.1713-.031.2814-.0332.4565l-1.0078.412.0495.2499.9598-.4492c.002.1339.008.2053.0207.3407.2667 2.8371 2.6364 3.3981 5.4677 3.1118 2.8312-.2863 5.0517-1.3114 4.785-4.1486-.013-.1361-.0324-.2068-.0553-.3392l1.0397.2257.0242-.229-1.0906-.207c-.0342-.1687-.0765-.271-.1264-.4327l1.1208-.1374-.0158-.2019-1.1499.1409a5.1093 5.1093 0 0 0-.1665-.4259l1.2665-.4042-.0397-.2536-1.3471.4667c-.819-1.7168-2.5002-2.8224-4.4546-2.8482Z"
                    ></path>
                </svg>
                <span>Qiita</span>
            </a>
        </nav>

        <!-- ページナビ -->
        <nav class="page-nav" aria-label="ページナビ">
            <a href="/">Home</a>
            <span class="sep">·</span>
            <a href="/blog">Blog</a>
            <span class="sep">·</span>
            <a href="/works">Works</a>
            <span class="sep">·</span>
            <a href="/about">About</a>
        </nav>

        <!-- 時間帯メッセージ (JavaScriptで描画) -->
        <p class="time-message" id="footer-time-msg"># ...</p>

        <!-- クレジット -->
        <p class="credit">
            &copy; {year} ToraMutton · Built with <a
                href="https://astro.build"
                target="_blank"
                rel="noopener noreferrer">Astro</a
            >
        </p>

        <!-- おまけ -->
        <p class="kaomoji">( ∩՞ټ՞∩) ﾝﾌ～～</p>
    </div>
</footer>

<script>
    document.addEventListener("astro:page-load", () => {
        const el = document.getElementById("footer-time-msg");
        if (!el) return;

        // Asia/Tokyo の「時」を 0〜23 で取得
        const hourStr = new Intl.DateTimeFormat("en-US", {
            timeZone: "Asia/Tokyo",
            hour: "2-digit",
            hourCycle: "h23",
        }).format(new Date());
        let hour = parseInt(hourStr, 10);
        if (Number.isNaN(hour) || hour === 24) hour = 0;

        let pool: string[];
        if (hour <= 4) {
            pool = ["# はよ寝ろ", "# 日付跨いでますよ！早く気づいて！"];
        } else if (hour <= 6) {
            pool = [
                "# そろそろ能力が高い人が起きてきそう",
                "# 早起きか、夜更かしか",
            ];
        } else if (hour <= 11) {
            pool = ["# おはようございます！", "# ド級の起床、ド起床"];
        } else if (hour <= 17) {
            pool = ["# 午後もがんばれ", "# 眠くなってくる時間帯"];
        } else if (hour <= 21) {
            pool = ["# お疲れ様です", "# 脱くねくね"];
        } else {
            // 22〜23時
            pool = ["# そろそろ寝ろ", "# おやすみなさい！"];
        }

        el.textContent = pool[Math.floor(Math.random() * pool.length)];
    });
</script>

<style>
    footer {
        position: relative;
        /* overflow は設定しない → AA がはみ出してもOK */
        margin-top: auto;
        padding: 3rem 1rem 2.5rem;
        border-top: 1px solid var(--border-color);
        background: var(--background);
    }

    /* === 背景: Arch ASCIIアート === */
    .footer-bg {
        position: absolute;
        /* 右下コーナーに寄せる。少しはみ出すくらいがちょうどいい */
        bottom: -1rem;
        right: -1rem;
        margin: 0;
        padding: 0;
        z-index: 0;

        font-family: var(--font-mono);
        font-size: clamp(0.45rem, 2.4vw, 0.8rem);
        line-height: 1.15;
        white-space: pre;
        color: var(--text-muted);
        opacity: 0.09;

        /* pre デフォルトのスクロールバーを潰す */
        overflow: hidden;
        pointer-events: none;
        user-select: none;
    }

    /* === メインカラム === */
    .footer-main {
        position: relative;
        z-index: 1;
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        text-align: center;
    }

    /* === SNS リンク === */
    .social-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.6rem;
    }

    .social-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.4rem 0.8rem;

        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 600;
        text-decoration: none;
        color: var(--text-muted);

        /* 背景ASCIIと被っても読めるよう不透明な surface 系で塗る */
        background: var(--elevated, var(--surface));
        border: 1px solid var(--border-color);
        border-radius: 4px;

        transition:
            color 0.2s ease,
            border-color 0.2s ease;
    }

    .social-link svg {
        flex-shrink: 0;
    }

    /* === ページナビ === */
    .page-nav {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;

        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    .page-nav a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .page-nav .sep {
        color: var(--border-color);
        opacity: 0.8;
        user-select: none;
    }

    /* === 時間帯メッセージ === */
    .time-message {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-muted);
        letter-spacing: 0.02em;
    }

    /* === クレジット === */
    .credit {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--text-muted);
        letter-spacing: 0.02em;
    }

    .credit a {
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s ease;
    }

    /* === おまけ === */
    .kaomoji {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--text-muted);
        opacity: 0.65;
    }

    /* === hover (ポインタデバイスのみ) === */
    @media (hover: hover) {
        .social-link:hover {
            color: var(--accent-blue);
            border-color: var(--accent-blue);
        }

        .page-nav a:hover,
        .credit a:hover {
            color: var(--accent-blue);
        }
    }

    /* === reduced-motion 配慮 === */
    @media (prefers-reduced-motion: reduce) {
        .social-link,
        .page-nav a,
        .credit a {
            transition: none;
        }
    }

    /* === モバイル === */
    @media (max-width: 720px) {
        footer {
            padding: 2.5rem 1rem 2rem;
        }

        .footer-bg {
            font-size: clamp(0.36rem, 3vw, 0.58rem);
            opacity: 0.07;
            bottom: -0.5rem;
            right: -0.5rem;
        }

        .footer-main {
            gap: 1rem;
        }

        .social-link {
            font-size: 0.74rem;
            padding: 0.38rem 0.7rem;
        }
    }
</style>
