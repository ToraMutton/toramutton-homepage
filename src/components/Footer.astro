<script>
    document.addEventListener("astro:page-load", () => {
        const el = document.getElementById("footer-time-msg");
        if (!el) return;

        // Asia/Tokyo の「時」を 0〜23 で取得
        const hourStr = new Intl.DateTimeFormat("en-US", {
            timeZone: "Asia/Tokyo",
            hour: "2-digit",
            hourCycle: "h23",
        }).format(new Date());
        let hour = parseInt(hourStr, 10);
        if (Number.isNaN(hour) || hour === 24) hour = 0;

        let pool: string[];
        if (hour <= 4) {
            pool = ["# はよ寝ろ", "# 日付跨いでますよ！早く気づいて！"];
        } else if (hour <= 6) {
            pool = [
                "# そろそろ能力が高い人が起きてきそう",
                "# 早起きか、夜更かしか",
            ];
        } else if (hour <= 11) {
            pool = ["# おはようございます！", "# ド級の起床、ド起床"];
        } else if (hour <= 17) {
            pool = ["# 午後もがんばれ", "# 眠くなってくる時間帯"];
        } else if (hour <= 21) {
            pool = ["# お疲れ様です", "# 脱くねくね"];
        } else {
            // 22〜23時
            pool = ["# そろそろ寝ろ", "# おやすみなさい！"];
        }

        el.textContent = pool[Math.floor(Math.random() * pool.length)];
    });
</script>

<style>
    footer {
        position: relative;
        /* overflow は設定しない → AA がはみ出してもOK */
        margin-top: auto;
        padding: 3rem 1rem 2.5rem;
        border-top: 1px solid var(--border-color);
        background: var(--background);
    }

    /* === 背景: Hex Dump with maji === */
    .footer-hex {
        position: absolute;
        bottom: -0.5rem;
        left: -0.5rem;
        width: 40%;
        max-height: 100%;
        z-index: 0;

        font-family: var(--font-mono);
        font-size: clamp(0.4rem, 1.8vw, 0.7rem);
        line-height: 1.4;
        word-break: break-all;
        color: var(--text-muted);
        opacity: 0.5;
        text-transform: uppercase;

        /* 上に向かって徐々に消えていくグラデーションマスク */
        mask-image: linear-gradient(to top right, black 10%, transparent 80%);
        -webkit-mask-image: linear-gradient(
            to top right,
            black 10%,
            transparent 80%
        );

        overflow: hidden;
        pointer-events: none;
        user-select: none;
    }

    /* === 背景: Arch ASCIIアート === */
    .footer-bg {
        position: absolute;
        bottom: -1rem;
        right: -1rem;
        margin: 0;
        padding: 0;
        z-index: 0;

        font-family: var(--font-mono);
        font-size: clamp(0.45rem, 2.4vw, 0.8rem);
        line-height: 1.15;
        white-space: pre;
        color: var(--text-muted);
        opacity: 0.28;

        /* global.css の pre デフォルトスタイルを上書き */
        background: transparent;
        border: none;
        border-radius: 0;
        padding: 0;
        /* pre デフォルトのスクロールバーを潰す */
        overflow: hidden;
        pointer-events: none;
        user-select: none;
    }

    /* === メインカラム === */
    .footer-main {
        position: relative;
        z-index: 1;
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        text-align: center;
    }

    /* === 時間帯メッセージ === */
    .time-message {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-muted);
        letter-spacing: 0.02em;
    }

    /* === クレジット === */
    .credit {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--text-muted);
        letter-spacing: 0.02em;
    }

    .credit a {
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 600;
        transition: color 0.2s ease;
    }

    /* === おまけ === */
    .kaomoji {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--text-muted);
        opacity: 0.65;
    }

    /* === hover (ポインタデバイスのみ) === */
    @media (hover: hover) {
        .credit a:hover {
            color: var(--accent-blue);
        }
    }

    /* === reduced-motion 配慮 === */
    @media (prefers-reduced-motion: reduce) {
        .credit a {
            transition: none;
        }
    }

    /* === モバイル === */
    @media (max-width: 720px) {
        footer {
            padding: 2.5rem 1rem 2rem;
        }

        /* モバイル時のHex表示領域調整 */
        .footer-hex {
            width: 50%;
            font-size: clamp(0.35rem, 2.5vw, 0.6rem);
            bottom: -0.2rem;
            left: -0.2rem;
        }

        .footer-bg {
            font-size: clamp(0.36rem, 3vw, 0.58rem);
            opacity: 0.22;
            bottom: -0.5rem;
            right: -0.5rem;
        }

        .footer-main {
            gap: 1rem;
        }
    }
</style>
