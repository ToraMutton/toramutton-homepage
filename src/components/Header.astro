---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import { Menu, X, Sun, Moon, BookOpenText } from "lucide-astro";
---

<header id="site-header">
    <nav>
        <div class="logo-group">
            <h2>
                <a href="/" class="title-link">
                    <img
                        class="logo-icon"
                        src="/toramutton.jpg"
                        alt="icon"
                        width={32}
                        height={32}
                    />
                    <span class="logo-text">ToraMutton</span>
                </a>
            </h2>
        </div>

        <div id="nav-links" class="internal-links">
            <HeaderLink href="/">Home</HeaderLink>
            <HeaderLink href="/blog">Blog</HeaderLink>
            <HeaderLink href="/works">Works</HeaderLink>
            <HeaderLink href="/about">About</HeaderLink>
        </div>

        <div class="controls-group">
            <button
                id="toc-toggle"
                class="toc-toggle ctrl-btn"
                aria-label="目次を開く"
            >
                <div class="icon-container-toc">
                    <span class="icon-toc-open"><BookOpenText size={22} /></span
                    >
                    <span class="icon-toc-close"><X size={22} /></span>
                </div>
            </button>

            <button
                id="theme-toggle"
                class="theme-toggle ctrl-btn"
                aria-label="テーマ切り替え"
            >
                <div class="icon-container-theme">
                    <span class="icon-sun"><Sun size={22} /></span>
                    <span class="icon-moon"><Moon size={22} /></span>
                </div>
            </button>

            <button
                id="menu-toggle"
                class="menu-toggle ctrl-btn"
                aria-label="メニューを開く"
                aria-expanded="false"
            >
                <div class="icon-container-menu">
                    <span class="icon-menu"><Menu size={24} /></span>
                    <span class="icon-close"><X size={24} /></span>
                </div>
            </button>
        </div>
    </nav>
</header>

<script>
    // テーマ切り替え関数
    function toggleTheme() {
        const element = document.documentElement;
        element.classList.toggle("dark");
        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
    }

    document.addEventListener("astro:page-load", () => {
        // --- 0. 目次ボタンの表示制御 ---
        const tocToggle = document.getElementById("toc-toggle");
        const tocSidebar = document.querySelector(".blog-toc");
        if (tocToggle && tocSidebar) {
            tocToggle.classList.add("has-toc");
            tocToggle.onclick = () => {
                tocSidebar.classList.toggle("mobile-open");
                tocToggle.classList.toggle("active");

                const menuToggle = document.getElementById("menu-toggle");
                const navLinks = document.getElementById("nav-links");
                const header = document.getElementById("site-header");
                if (menuToggle && menuToggle.classList.contains("open")) {
                    menuToggle.classList.remove("open");
                    menuToggle.setAttribute("aria-expanded", "false");
                    if (navLinks) navLinks.classList.remove("open");
                    if (header) header.classList.remove("menu-open");
                }
            };
        }

        // --- 1. ハンバーガーメニュー ---
        const menuToggle = document.getElementById("menu-toggle");
        const navLinks = document.getElementById("nav-links");
        const header = document.getElementById("site-header");

        if (menuToggle && navLinks && header) {
            menuToggle.onclick = () => {
                const isExpanded =
                    menuToggle.getAttribute("aria-expanded") === "true";
                menuToggle.setAttribute(
                    "aria-expanded",
                    !isExpanded ? "true" : "false",
                );
                menuToggle.classList.toggle("open");
                navLinks.classList.toggle("open");
                header.classList.toggle("menu-open");
            };
        }

        // --- 2. テーマ切り替え（View Transition: circle-reveal 維持）---
        const themeToggle = document.getElementById("theme-toggle");
        if (themeToggle) {
            themeToggle.onclick = (e: MouseEvent) => {
                const x = e.clientX;
                const y = e.clientY;
                document.documentElement.style.setProperty("--tx", `${x}px`);
                document.documentElement.style.setProperty("--ty", `${y}px`);
                // @ts-ignore
                if (!document.startViewTransition) {
                    toggleTheme();
                    return;
                }
                document.documentElement.classList.add("theme-transitioning");
                // @ts-ignore
                const transition = document.startViewTransition(() =>
                    toggleTheme(),
                );
                transition.finished.then(() => {
                    document.documentElement.classList.remove(
                        "theme-transitioning",
                    );
                });
            };
        }
    });
</script>

<style>
    /* === 基本設定 === */
    header {
        --header-height: 64px;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 9999;
        margin: 0;
        padding: 0 1.5rem;
        background: color-mix(in srgb, var(--background) 94%, transparent);
        border-bottom: 1px solid var(--border-color);
        transition:
            border-color 0.3s,
            background-color 0.3s;
    }
    header.menu-open {
        border-bottom-color: transparent;
    }

    nav {
        display: flex;
        align-items: center;
        height: var(--header-height);
        max-width: 1100px;
        margin: 0 auto;
        position: relative;
    }

    /* logo 左、nav-links → controls の順で右寄せ */
    .logo-group {
        order: 1;
        margin-right: auto;
        min-width: 0;
        z-index: 1001;
    }
    .internal-links {
        order: 2;
    }
    .controls-group {
        order: 3;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        margin-left: 1rem;
        flex-shrink: 0;
        z-index: 1001;
    }

    /* === ロゴ === */
    h2 {
        margin: 0;
        line-height: 1;
        font-size: 1.05rem;
        font-weight: 700;
        border-bottom: none !important;
        padding-bottom: 0 !important;
    }
    .title-link {
        /* fit-content で当たり判定をテキスト幅に固定（押し間違い対策） */
        width: fit-content;
        max-width: 100%;
        color: var(--text-main) !important;
        text-decoration: none !important;
        border: none !important;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transition: color 0.2s;
    }
    .logo-icon {
        border-radius: var(--radius); /* 50% → 4px */
        object-fit: cover;
        flex-shrink: 0;
    }
    .logo-text {
        font-family: var(--font-mono);
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .title-link:hover {
        color: var(--accent-blue) !important;
    }

    /* === コントロールボタン共通 === */
    .ctrl-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: none;
        outline: none;
        cursor: pointer;
        color: inherit;
        padding: 0;
        width: 40px;
        height: 40px;
        border-radius: var(--radius); /* 50% → 4px */
        transition:
            background 0.2s,
            color 0.2s;
    }
    @media (hover: hover) {
        .ctrl-btn:hover {
            background: color-mix(in srgb, var(--accent-blue) 12%, transparent);
            color: var(--accent-blue);
        }
    }
    .ctrl-btn:active {
        transform: scale(0.92);
        background: color-mix(in srgb, var(--accent-blue) 18%, transparent);
    }

    /* === TOC トグル（LOCAL記事 + ≤1279px のみ表示）=== */
    .toc-toggle {
        display: none;
    }
    .icon-container-toc {
        position: relative;
        width: 22px;
        height: 22px;
    }
    .icon-toc-open,
    .icon-toc-close {
        position: absolute;
        top: 0;
        left: 0;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .icon-toc-open {
        opacity: 1;
        transform: rotate(0deg) scale(1);
    }
    .icon-toc-close {
        opacity: 0;
        transform: rotate(-90deg) scale(0.5);
    }
    .toc-toggle.active .icon-toc-open {
        opacity: 0;
        transform: rotate(90deg) scale(0.5);
    }
    .toc-toggle.active .icon-toc-close {
        opacity: 1;
        transform: rotate(0deg) scale(1);
    }
    .toc-toggle.active {
        color: var(--accent-blue);
        background: color-mix(in srgb, var(--accent-blue) 12%, transparent);
    }
    @media (max-width: 1279px) {
        .toc-toggle.has-toc {
            display: flex;
        }
    }

    /* === テーマトグル（Sun/Moon 維持）=== */
    .icon-container-theme {
        position: relative;
        width: 22px;
        height: 22px;
    }
    .icon-sun,
    .icon-moon {
        position: absolute;
        top: 0;
        left: 0;
        transition: all 0.5s cubic-bezier(0.68, -0.55, 0.27, 1.55);
    }
    :global(html.dark) .icon-sun {
        transform: rotate(90deg) scale(0.4);
        opacity: 0;
    }
    :global(html.dark) .icon-moon {
        transform: rotate(0deg) scale(1);
        opacity: 1;
    }
    :global(html:not(.dark)) .icon-sun {
        transform: rotate(0deg) scale(1);
        opacity: 1;
    }
    :global(html:not(.dark)) .icon-moon {
        transform: rotate(-90deg) scale(0.4);
        opacity: 0;
    }

    /* === ハンバーガー（PC非表示）=== */
    .menu-toggle {
        display: none;
    }
    .icon-container-menu {
        position: relative;
        width: 24px;
        height: 24px;
    }
    .icon-menu,
    .icon-close {
        position: absolute;
        top: 0;
        left: 0;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .icon-menu {
        opacity: 1;
        transform: rotate(0deg) scale(1);
    }
    .icon-close {
        opacity: 0;
        transform: rotate(-90deg) scale(0.5);
    }
    .menu-toggle.open .icon-menu {
        opacity: 0;
        transform: rotate(90deg) scale(0.5);
    }
    .menu-toggle.open .icon-close {
        opacity: 1;
        transform: rotate(0deg) scale(1);
    }

    /* === ナビリンク === */
    .internal-links {
        display: flex;
        gap: 1.6rem;
    }
    .internal-links :global(a) {
        position: relative;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.5rem 0;
        transition: color 0.2s;
    }
    /* active: ▸ プロンプト + text-main */
    .internal-links :global(a)::before {
        content: "▸";
        position: absolute;
        left: -1.1em;
        opacity: 0;
        color: var(--accent-blue);
        transition: opacity 0.2s;
    }
    .internal-links :global(a.active) {
        color: var(--text-main);
    }
    .internal-links :global(a.active)::before {
        opacity: 1;
    }
    @media (hover: hover) {
        .internal-links :global(a:hover) {
            color: var(--accent-blue);
        }
    }

    /* === スマホ・タブレット（≤720px）=== */
    @media (max-width: 720px) {
        /* タップ領域拡大（押し間違い対策）*/
        .ctrl-btn {
            width: 44px;
            height: 44px;
        }
        .menu-toggle {
            display: flex;
            z-index: 1002;
        }

        .internal-links {
            position: absolute;
            top: 100%;
            left: 50%;
            margin-left: -50vw;
            width: 100vw;
            display: flex;
            flex-direction: column;
            gap: 0;
            /* glass 廃止 → solid surface / box-shadow 廃止 → border のみ */
            background: var(--surface);
            border-top: 1px solid var(--border-color);
            border-bottom: 1px solid var(--border-color);
            border-radius: 0;
            max-height: 0;
            opacity: 0;
            transform: translateY(-8px);
            visibility: hidden;
            transition:
                max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.3s ease,
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            overflow: hidden;
        }
        .internal-links.open {
            max-height: 400px;
            opacity: 1;
            transform: translateY(0);
            visibility: visible;
        }

        /* モバイルリンク：terminal 風（▸ + mono、左揃え）*/
        .internal-links :global(a) {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 1.1rem 1.5rem;
            width: 100%;
            font-size: 0.95rem;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border-color);
            opacity: 0;
            transform: translateY(-4px);
            transition:
                opacity 0.3s ease,
                transform 0.3s ease;
        }
        .internal-links.open :global(a) {
            opacity: 1;
            transform: translateY(0);
            transition-delay: 0.1s;
        }
        /* モバイルは静的 ▸ プロンプト（全リンク先頭に表示）*/
        .internal-links :global(a)::before {
            position: static;
            opacity: 0.5;
            color: var(--text-muted);
        }
        .internal-links :global(a:last-child) {
            border-bottom: none;
        }
        .internal-links :global(a.active) {
            color: var(--accent-blue);
            background: color-mix(in srgb, var(--accent-blue) 8%, transparent);
        }
        .internal-links :global(a.active)::before {
            opacity: 1;
            color: var(--accent-blue);
        }
    }

    /* === 極狭幅（≤480px）：ロゴはアイコンのみ＝デッドゾーン最大化 === */
    @media (max-width: 480px) {
        .logo-text {
            display: none;
        }
    }
</style>
