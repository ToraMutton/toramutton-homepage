// --- Timeline (git log style / newest first) ---
const TIMELINE = [
    { date: "2026.05.30", desc: "ホームページをターミナル風デザインに大改造" },
    { date: "2026.04.24", desc: "UEC Career Boot Festa 2026のNOCに参加" },
    { date: "2026.03.10", desc: "基本情報技術者試験 合格" },
    { date: "2026.01.02", desc: "Astroでホームページを作成" },
    { date: "2025.04.14", desc: "MMA 入部" },
    { date: "2025.04.04", desc: "電気通信大学Ⅰ類 入学" },
    { date: "2022.04.07", desc: "都立三田高校 入学" },
    { date: "2006.06.20", desc: "誕生" },
];
---

<Layout
    title="自己紹介 / About Me"
    description="トラマトのプロフィール、経歴、技術、環境など"
>
    <div class="about-content">
        {/* 1. bio */}
        <section class="bio" data-reveal>
            <div class="bio-prompt">
                <span class="env-dollar">$</span><span class="bio-typed"
                    >cat ./README.md</span
                >
            </div>

            <div class="bio-body reveal-item">
                <p>
                    電気通信大学 情報理工学域 I 類の
                    <strong>ToraMutton / トラマト</strong>です。 寅松
                    真人(とらまつ まさと)はGrok君が考えてくれた偽名です。<br />
                    MMAというサークルに所属していて、 Twitterに生息しています。<br
                    />
                    Web・コンパイラ・LLMあたりに興味があり、 最近はArch LinuxとWindows11の両方でRicingを楽しんでます。
                </p>
            </div>

            <a
                class="bio-cta env-cmd reveal-item"
                href="https://note.com/toramutton/n/n338320294cf6"
                target="_blank"
                rel="noopener noreferrer"
            >
                <span class="env-dollar">$</span>
                <span class="env-cmd-text">cat ~/profile/intro.md</span>
                <span class="env-comment env-tag"
                    ># より詳しい自己紹介はこちら</span
                >
                <span class="env-arrow">↗</span>
            </a>
        </section>

        {/* 4. Skills & Tools */}
        <h2>Skills & Tools</h2>

        <section class="skill-section">
            <p class="skill-intro"># 使用している言語とかツールとか</p>

            {
                SKILL_GROUPS.map((group) => (
                    <div class="skill-category">
                        <div class="skill-cmd">
                            <span class="env-dollar">$</span>
                            <span class="skill-cmd-text">{group.cmd}</span>
                            <span class="env-comment">// {group.note}</span>
                        </div>
                        <div class="skill-grid" data-reveal>
                            {group.items.map((skill) => (
                                <div
                                    class="skill-card reveal-item"
                                    tabindex="0"
                                >
                                    <span
                                        class={`icon-wrapper ${skill.darkInvert ? "dark-invert" : ""}`}
                                    >
                                        <img
                                            src={skill.src}
                                            alt={skill.name}
                                            class="skill-img"
                                            width="48"
                                            height="48"
                                            loading="lazy"
                                        />
                                    </span>
                                    <span class="skill-name">{skill.name}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                ))
            }
        </section>

        {/* 2. Interests & Hobbies */}
        <h2>Interests & Hobbies</h2>

        <div class="environments">
            <div class="env-terminal" aria-label="interests config">
                <div class="env-line env-promptline">
                    <span class="env-dollar">$</span>
                    <span class="env-typed">cat ~/.config/interests</span>
                </div>

                {
                    INTERESTS.map((block) => (
                        <div class="env-block">
                            <div class="env-line env-section-head">
                                <span class="env-bracket">[</span>
                                <span class="env-section">{block.section}</span>
                                <span class="env-bracket">]</span>
                            </div>
                            <div class="env-line int-row">
                                {block.items.map((item) => (
                                    <span class="int-tag">{item}</span>
                                ))}
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        {/* 3. Environments */}
        <h2 id="trapezium">Environments</h2>

        <div class="environments">
            <div class="env-terminal" aria-label="environments config">
                {/* prompt */}
                <div class="env-line env-promptline">
                    <span class="env-dollar">$</span>
                    <span class="env-typed">cat ~/.config/environments</span>
                </div>

                {/* output: ini blocks */}
                {
                    ENV_BLOCKS.map((block) => (
                        <div class="env-block">
                            <div class="env-line env-section-head">
                                <span class="env-bracket">[</span>
                                <span class="env-section">{block.section}</span>
                                <span class="env-bracket">]</span>
                                {block.meta && (
                                    <span class="env-comment">
                                        # {block.meta}
                                    </span>
                                )}
                            </div>
                            {block.rows.map((row) => (
                                <div class="env-line env-row">
                                    <span class="env-k">{row.k}</span>
                                    <span class="env-eq">=</span>
                                    <span class="env-v">{row.v}</span>
                                </div>
                            ))}
                            {block.link && (
                                <a
                                    class="env-line env-cmd env-cmd--inline"
                                    href={block.link.href}
                                >
                                    <span class="env-dollar">$</span>
                                    <span class="env-cmd-text">
                                        {block.link.cmd}
                                    </span>
                                    <span class="env-comment env-tag">
                                        # {block.link.tag}
                                    </span>
                                    <span class="env-arrow">→</span>
                                </a>
                            )}
                        </div>
                    ))
                }
            </div>
        </div>

        {/* 5. Timeline (git log style) */}
        <h2>Timeline</h2>
        <div class="timeline" data-reveal>
            <div class="git-line" aria-hidden="true">
                <span class="git-dollar">$</span> git log --oneline --graph
            </div>
            {
                TIMELINE.map((item) => (
                    <div class="git-row reveal-item">
                        <span class="git-date">{item.date}</span>
                        <span class="git-msg">{item.desc}</span>
                    </div>
                ))
            }
        </div>
    </div>

    <script>
        // === h2 下線 reveal ===
        const h2Observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("visible");
                    }
                });
            },
            { threshold: 0.5 },
        );
        document.querySelectorAll(".about-content h2").forEach((h2) => {
            h2Observer.observe(h2);
        });

        const reduceMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
        ).matches;

        if (!reduceMotion) {
            // === 汎用 stagger reveal（[data-reveal] 内の .reveal-item）===
            const revealObserver = new IntersectionObserver(
                (entries, obs) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-revealed");
                            obs.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.12 },
            );
            document
                .querySelectorAll<HTMLElement>("[data-reveal]")
                .forEach((container) => {
                    const items = Array.from(
                        container.querySelectorAll<HTMLElement>(".reveal-item"),
                    );
                    items.forEach((el, i) => {
                        el.style.transitionDelay = `${i * 50}ms`;
                    });
                    container.classList.add("reveal-ready");
                    revealObserver.observe(container);
                });

            // === ターミナルブロック（env / interests）の行 stagger reveal ===
            const termObserver = new IntersectionObserver(
                (entries, obs) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-revealed");
                            obs.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.15 },
            );
            document
                .querySelectorAll<HTMLElement>(".env-terminal")
                .forEach((term) => {
                    const lines = Array.from(
                        term.querySelectorAll<HTMLElement>(".env-line"),
                    );
                    lines.forEach((el, i) => {
                        el.style.transitionDelay = `${i * 40}ms`;
                    });
                    term.classList.add("reveal-ready");
                    termObserver.observe(term);
                });
        }
    </script>

    <style>
        /* === 1. 基本設定・リセット === */
        :global(.last-updated-on),
        :global(time) {
            display: none;
        }

        .about-content {
            line-height: 1.8;
            color: var(--text-main);
            padding-top: 2.5rem;
        }

        /* === h2のカスタム設定 === */
        .about-content h2 {
            position: relative;
            display: block;
            width: 100%;
            margin-top: 4rem;
            margin-bottom: 1.5rem;
            border: none !important;
            padding-bottom: 5px;
        }
        .about-content h2::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: 0;
            height: 1px;
            width: 0%;
            background-color: var(--accent-blue);
            transition: width 0.8s ease-out;
        }
        .about-content h2.visible::after {
            width: 100%;
        }

        /* === ライトモード視認性調整 === */
        :global(html:not(.dark)) {
            .skill-cmd-text {
                color: #1d4ed8;
            }
        }

        /* === 汎用 stagger reveal === */
        [data-reveal] .reveal-item {
            transition:
                opacity 0.5s ease,
                transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
        }
        [data-reveal].reveal-ready:not(.is-revealed) .reveal-item {
            opacity: 0;
            transform: translateY(12px);
        }
        @media (prefers-reduced-motion: reduce) {
            [data-reveal] .reveal-item {
                opacity: 1 !important;
                transform: none !important;
                transition: none !important;
            }
        }

        /* === bio（散文 + ターミナル風プロンプト）=== */
        .bio {
            margin-bottom: 1rem;
        }
        .bio-prompt {
            font-family: var(--font-mono);
            color: var(--text-main);
            margin-bottom: 0.9rem;
        }
        .bio-typed {
            display: inline-block;
            overflow: hidden;
            white-space: nowrap;
            vertical-align: bottom;
            max-width: 0;
            /* Hero と統一: 2px の縦棒カーソル */
            border-right: 2px solid var(--accent-blue);
            animation:
                bio-typing 1s steps(15, end) 0.15s forwards,
                bio-caret 0.7s step-end 3 1.2s;
        }
        @keyframes bio-typing {
            to {
                max-width: 16ch;
            }
        }
        @keyframes bio-caret {
            50% {
                border-color: transparent;
            }
        }
        @media (prefers-reduced-motion: reduce) {
            .bio-typed {
                animation: none;
                border-right: none;
                max-width: none;
            }
        }

        .bio-body {
            padding-left: 1.2rem;
            border-left: 1px solid var(--border-color);
            color: var(--text-main);
            line-height: 1.9;
        }
        .bio-body p {
            margin: 0;
        }

        .bio-cta {
            margin-top: 1.5rem;
        }

        /* === Skills === */
        .skill-section {
            margin: 2rem 0;
        }
        .skill-intro {
            margin: 0 0 2rem;
            color: var(--text-muted);
            font-family: var(--font-mono);
            font-size: 0.85rem;
        }
        .skill-category {
            margin-bottom: 2.8rem;
        }
        .skill-cmd {
            display: flex;
            align-items: baseline;
            flex-wrap: wrap;
            gap: 0 0.5rem;
            margin-bottom: 1.1rem;
            font-family: var(--font-mono);
        }
        .skill-cmd-text {
            color: var(--accent-blue);
            font-weight: 700;
        }

        .skill-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 0.8rem;
        }

        /* --- card: 脱グラス border-card / 名前は常時表示 --- */
        .skill-card {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            padding: 1rem 0.4rem;
            background: var(--surface);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            cursor: pointer;
            overflow: hidden;
            outline: none;
            -webkit-tap-highlight-color: transparent;
            transition: border-color 0.3s ease;
        }

        /* 斜め accent sweep（hover で左から走る = yui540 系）*/
        .skill-card::before {
            content: "";
            position: absolute;
            inset: -2px -45%;
            background: color-mix(in srgb, var(--accent-blue) 18%, transparent);
            transform: translateX(-135%) skewX(-14deg);
            transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
            z-index: 0;
        }

        .icon-wrapper {
            position: relative;
            z-index: 1;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .skill-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
        :global(html.dark) .icon-wrapper.dark-invert {
            filter: invert(0.92) hue-rotate(180deg) brightness(1.05);
        }

        .skill-name {
            position: relative;
            z-index: 1;
            font-family: var(--font-mono);
            font-size: 0.72rem;
            font-weight: 700;
            line-height: 1;
            color: var(--text-muted);
            transition: color 0.25s ease;
        }

        .skill-card:focus-visible {
            border-color: var(--accent-blue);
        }
        .skill-card:focus-visible::before {
            transform: translateX(0) skewX(-14deg);
        }
        .skill-card:focus-visible .skill-name {
            color: var(--accent-blue);
        }
        @media (hover: hover) {
            .skill-card:hover {
                border-color: var(--accent-blue);
            }
            .skill-card:hover::before {
                transform: translateX(0) skewX(-14deg);
            }
            .skill-card:hover .skill-name {
                color: var(--accent-blue);
            }
        }

        /* === Interests（env と共通のターミナル + 専用の行）=== */
        .int-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem 1.2rem;
            padding: 0.15rem 0 0.3rem 1.2rem;
        }
        .int-tag {
            position: relative;
            color: var(--text-main);
            font-family: var(--font-mono), var(--font-sans);
            cursor: default;
            transition: color 0.2s ease;
        }
        .int-tag::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: -2px;
            width: 0;
            height: 1px;
            background: var(--accent-blue);
            transition: width 0.25s ease;
        }
        @media (hover: hover) {
            .int-tag:hover {
                color: var(--accent-blue);
            }
            .int-tag:hover::after {
                width: 100%;
            }
        }

        /* === Timeline (git log --graph 風) === */
        .timeline {
            margin: 2rem 0 3rem;
            font-family: var(--font-mono);
            border-left: 1px solid var(--border-color);
            margin-left: 0.35rem;
        }
        .git-line {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin: 0 0 1.2rem 1.4rem;
            user-select: none;
        }
        .git-dollar {
