// --- 3. Operating Systems ---
const OS_SKILLS = [
    {
        name: "Windows",
        src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/windows8/windows8-original.svg",
    },
    {
        name: "Arch Linux",
        src: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/archlinux/archlinux-original.svg",
        darkInvert: true,
    },
