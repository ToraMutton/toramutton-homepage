const SKILL_GROUPS = [
    { title: "Programming & Web", icon: Terminal, items: PROG_SKILLS },
    { title: "Tools & Creative", icon: MousePointer2, items: TOOL_SKILLS },
    { title: "Operating Systems", icon: Cpu, items: OS_SKILLS },
];

// --- 4. Interests / 好きなこと ---
const INTERESTS = [
    {
        category: "Music",
        icon: Music,
        items: [
            "米津玄師",
            "Eve",
            "King Gnu",
            "Mrs. GREEN APPLE",
            "サカナクション",
            "ヨルシカ",
        ],
    },
    {
        category: "Game",
        icon: Gamepad2,
        items: [
            "Minecraft",
            "ブルーアーカイブ",
            "ポケモン",
            "スプラトゥーン",
            "バカゲー",
        ],
    },
    {
        category: "Other",
        icon: Coffee,
        items: [
            "映像制作",
            "Twitter",
            "アニメ",
            "漫画",
            "映画鑑賞",
            "睡眠",
            "キヨ。",
        ],
    },
];

// --- Environments (dotfile style) ---
const ENV_BLOCKS = [
    {
        section: "desktop",
        meta: "2026/02/13 ~",
        rows: [
            { k: "cpu", v: "AMD Ryzen 7 7700" },
            { k: "gpu", v: "Radeon RX 9060 XT 16GB" },
            { k: "mb", v: "ASUS A620M-K CSM" },
            { k: "memory", v: "DDR5 32GB" },
            { k: "storage", v: "SSD 2TB (NVMe)" },
            { k: "cooler", v: "虎徹 MarkⅡ" },
            { k: "case", v: "MONTECH AIR 903 MAX" },
            { k: "psu", v: "玄人志向 80PLUS Platinum 600W" },
            { k: "os", v: "Windows 11 Home & Arch Linux" },
        ],
        link: {
            cmd: "cd ./desktop && cat pc-build-2026.md",
            href: "/blog/pc-build-2026/",
            tag: "local",
        },
    },
    {
        section: "laptop",
        meta: "Dell 14 Plus / 2025/03/28 ~",
        rows: [
            { k: "cpu", v: "Core Ultra 7 258V" },
            { k: "gpu", v: "Intel Arc Graphics 140V" },
            { k: "memory", v: "32GB (MoP / LPDDR5x-8533)" },
            { k: "os", v: "Windows 11 Home" },
        ],
    },
    {
        section: "mobile",
        rows: [
            { k: "phone", v: "iPhone 16e" },
            { k: "tablet", v: "iPad Air M4" },
        ],
    },
    {
        section: "setup",
        rows: [
            { k: "monitor.main", v: "24-inch WQHD 180Hz" },
            { k: "monitor.sub", v: "27-inch WQHD 75Hz" },
            { k: "editor", v: "Neovim" },
            { k: "browser", v: "Google Chrome" },
            { k: "wm", v: "Hyprland" },
            { k: "bar", v: "Waybar" },
        ],
    },
];

// --- Timeline (git log style / newest first) ---
const TIMELINE = [
    { date: "2026.03.10", desc: "基本情報技術者試験 合格" },
    { date: "2026.01.02", desc: "Astroでホームページを作成" },
    { date: "2025.04.04", desc: "電気通信大学 入学" },
    { date: "2022.04.07", desc: "都立三田高校 入学" },
    { date: "2006.06.20", desc: "誕生" },
];
---

<Layout
    title="自己紹介 / About Me"
    description="トラマトのプロフィール、経歴、技術、環境など"
>
    <div class="about-content">
        {/* 1. bio */}
        <section class="bio">
            <p>
                電気通信大学 情報理工学域 I 類の<strong>トラマト</strong
                >です。<br />
                寅松 真人(とらまつ まさと)は偽名です。<br />
                MMAというサークルに所属しています。 主にTwitterかDiscordに生息しています。
            </p>
        </section>

        {/* 4. Skills & Tools */}
        <h2>Skills & Tools</h2>

        <section class="skill-section">
            <p class="skill-intro">使用している言語とかツールとか</p>

            {
                SKILL_GROUPS.map((group) => (
                    <div class="skill-category">
                        <h3 class="category-title">
                            <group.icon size={18} /> {group.title}
                        </h3>
                        <div class="skill-grid" data-reveal>
                            {group.items.map((skill) => (
                                <div
                                    class="skill-card reveal-item"
                                    tabindex="0"
                                >
                                    <span
                                        class={`icon-wrapper ${skill.darkInvert ? "dark-invert" : ""}`}
                                    >
                                        <img
                                            src={skill.src}
                                            alt={skill.name}
                                            class="skill-img"
                                            width="48"
                                            height="48"
                                            loading="lazy"
                                        />
                                    </span>
                                    <span class="skill-name">{skill.name}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                ))
            }
        </section>

        {/* 2. Interests & Hobbies */}
        <h2>Interests & Hobbies</h2>

        <div class="interests-grid" data-reveal>
            {
                INTERESTS.map((interest) => (
                    <div class="interest-card reveal-item">
                        <div class="interest-header">
                            <interest.icon class="interest-icon" size={18} />
                            <span class="interest-title">
                                {interest.category}
                            </span>
                        </div>

                        <div class="tags-wrapper">
                            {interest.items.map((item) => (
                                <span class="interest-tag">{item}</span>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>

        {/* 3. Environments */}
        <h2 id="trapezium">Environments</h2>

        <div class="environments">
            <div class="env-terminal" aria-label="environments config">
                {/* prompt */}
                <div class="env-line env-promptline">
                    <span class="env-dollar">$</span>
                    <span class="env-typed">cat ~/.config/environments</span>
                </div>

                {/* output: ini blocks */}
                {
                    ENV_BLOCKS.map((block) => (
                        <div class="env-block">
                            <div class="env-line env-section-head">
                                <span class="env-bracket">[</span>
                                <span class="env-section">{block.section}</span>
                                <span class="env-bracket">]</span>
                                {block.meta && (
                                    <span class="env-comment">
                                        # {block.meta}
                                    </span>
                                )}
                            </div>
                            {block.rows.map((row) => (
                                <div class="env-line env-row">
                                    <span class="env-k">{row.k}</span>
                                    <span class="env-eq">=</span>
                                    <span class="env-v">{row.v}</span>
                                </div>
                            ))}
                            {block.link && (
                                <a
                                    class="env-line env-cmd env-cmd--inline"
                                    href={block.link.href}
                                >
                                    <span class="env-dollar">$</span>
                                    <span class="env-cmd-text">
                                        {block.link.cmd}
                                    </span>
                                    <span class="env-comment env-tag">
                                        # {block.link.tag}
                                    </span>
                                    <span class="env-arrow">→</span>
                                </a>
                            )}
                        </div>
                    ))
                }

                {/* follow-up command (note) */}
                <div class="env-links">
                    <a
                        class="env-line env-cmd"
                        href="https://note.com/toramutton/n/n338320294cf6"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <span class="env-dollar">$</span>
                        <span class="env-cmd-text">cat ~/profile/intro.md</span>
                        <span class="env-comment env-tag"># note</span>
                        <span class="env-arrow">↗</span>
                    </a>
                </div>
            </div>
        </div>

        {/* 5. Timeline (git log style) */}
        <h2>Timeline</h2>
        <div class="timeline" data-reveal>
            <div class="git-line" aria-hidden="true">
                <span class="git-dollar">$</span> git log --oneline --graph
            </div>
            {
                TIMELINE.map((item) => (
                    <div class="git-row reveal-item">
                        <span class="git-date">{item.date}</span>
                        <span class="git-msg">{item.desc}</span>
                    </div>
                ))
            }
        </div>
    </div>

    <script>
        // === h2 下線 reveal（スクロールで一度発火）===
        const h2Observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("visible");
                    }
                });
            },
            { threshold: 0.5 },
        );
        document.querySelectorAll(".about-content h2").forEach((h2) => {
            h2Observer.observe(h2);
        });

        const reduceMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
        ).matches;

        // === 汎用 stagger reveal（[data-reveal] 内の .reveal-item をパラパラ表示）===
        if (!reduceMotion) {
            const revealObserver = new IntersectionObserver(
                (entries, obs) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-revealed");
                            obs.unobserve(entry.target); // 一度だけ
                        }
                    });
                },
                { threshold: 0.12 },
            );

            document
                .querySelectorAll<HTMLElement>("[data-reveal]")
                .forEach((container) => {
                    const items = Array.from(
                        container.querySelectorAll<HTMLElement>(".reveal-item"),
                    );
                    items.forEach((el, i) => {
                        el.style.transitionDelay = `${i * 55}ms`;
                    });
                    container.classList.add("reveal-ready");
                    revealObserver.observe(container);
                });
        }

        // === Environments: 一度だけ発火する reveal ===
        const envTerminal = document.querySelector(".env-terminal");
        if (envTerminal && !reduceMotion) {
            const lines = Array.from(
                envTerminal.querySelectorAll<HTMLElement>(".env-line"),
            );
            lines.forEach((el, i) => {
                el.style.transitionDelay = `${i * 45}ms`;
            });
            envTerminal.classList.add("reveal-ready");

            const envObserver = new IntersectionObserver(
                (entries, obs) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("is-revealed");
                            obs.unobserve(entry.target); // 一度だけ
                        }
                    });
                },
                { threshold: 0.15 },
            );
            envObserver.observe(envTerminal);
        }
    </script>

    <style>
        /* === 1. 基本設定・リセット === */
        :global(.last-updated-on),
        :global(time) {
            display: none;
        }

        .about-content {
            line-height: 1.8;
            color: var(--text-main);
        }

        /* === h2のカスタム設定 === */
        .about-content h2 {
            position: relative;
            display: block;
            width: 100%;
            margin-top: 4rem;
            margin-bottom: 1.5rem;
            border: none !important;
            padding-bottom: 5px;
        }

        /* 下線の設定 */
        .about-content h2::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: 0;
            height: 1px;
            width: 0%;
            background-color: var(--accent-blue);
            transition: width 0.8s ease-out;
        }

        .about-content h2.visible::after {
            width: 100%;
        }

        /* === ライトモード視認性調整 === */
        :global(html:not(.dark)) {
            .category-title {
                color: #1d4ed8;
                opacity: 1;
            }
        }

        /* === 汎用 stagger reveal === */
        [data-reveal] .reveal-item {
            transition:
                opacity 0.5s ease,
                transform 0.5s ease;
        }
        [data-reveal].reveal-ready:not(.is-revealed) .reveal-item {
            opacity: 0;
            transform: translateY(10px);
        }
        @media (prefers-reduced-motion: reduce) {
            [data-reveal] .reveal-item {
                opacity: 1 !important;
                transform: none !important;
                transition: none !important;
            }
        }

        /* === 5. スキルアイコン・グリッド === */
        .skill-section {
            margin: 2rem 0;
            text-align: center;
        }
        .skill-intro {
            margin-bottom: 2rem;
            color: var(--text-main);
            opacity: 0.8;
            font-size: 0.9rem;
        }
        .skill-category {
            margin-bottom: 3.5rem;
        }
        .category-title {
            font-size: 0.9rem;
            margin: 0 0 1.5rem 0;
            color: var(--accent-blue);
            font-family: var(--font-mono);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .skill-grid {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 1rem;
        }

        /* --- card: 脱グラス border-card --- */
        .skill-card {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100px;
            height: 100px;
            background: var(--surface);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            padding: 0;
            cursor: pointer;
            overflow: hidden;
            outline: none;
            -webkit-tap-highlight-color: transparent;
            transition: border-color 0.3s ease;
        }

        /* 斜め clip 風の accent sweep（hover で左から走る = yui540 系斜め演出）*/
        .skill-card::before {
            content: "";
            position: absolute;
            inset: -2px -40%;
            background: color-mix(in srgb, var(--accent-blue) 14%, transparent);
            transform: translateX(-130%) skewX(-14deg);
            transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
            z-index: 0;
        }

        .icon-wrapper {
            position: relative;
            z-index: 1;
            width: 56px;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: center;
            transform: translateY(0);
            transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        .skill-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        /* dark mode: 暗色ロゴ（GitHub / Rust / Bash 等）を反転して可視化 */
        :global(html.dark) .icon-wrapper.dark-invert {
            filter: invert(0.92) hue-rotate(180deg) brightness(1.05);
        }

        .skill-name {
            position: absolute;
            z-index: 2;
            bottom: 12px;
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--accent-blue);
            font-family: var(--font-mono);
            line-height: 1;
            opacity: 0;
            transform: translateY(16px);
            transition:
                opacity 0.3s ease,
                transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        /* keyboard focus（タッチ／キーボード両対応）*/
        .skill-card:focus-visible {
            border-color: var(--accent-blue);
        }
        .skill-card:focus-visible::before {
            transform: translateX(0) skewX(-14deg);
        }
        .skill-card:focus-visible .icon-wrapper {
            transform: translateY(-13px);
        }
        .skill-card:focus-visible .skill-name {
            opacity: 1;
            transform: translateY(0);
        }

        /* hover: pointer devices only */
        @media (hover: hover) {
            .skill-card:hover {
                border-color: var(--accent-blue);
            }
            .skill-card:hover::before {
                transform: translateX(0) skewX(-14deg);
            }
            .skill-card:hover .icon-wrapper {
                transform: translateY(-13px);
            }
            .skill-card:hover .skill-name {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* === 6. 興味・好きなこと === */
        .interests-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            margin-bottom: 3rem;
        }
        @media (min-width: 768px) {
            .interests-grid {
                grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            }
        }

        /* --- card: 脱グラス border-card --- */
        .interest-card {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            background: var(--surface);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            padding: 1.5rem;
            transition: border-color 0.25s ease;
        }
        @media (hover: hover) {
            .interest-card:hover {
                border-color: color-mix(
                    in srgb,
                    var(--accent-blue) 55%,
                    var(--border-color)
                );
            }
        }

        .interest-header {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 0.8rem;
        }
        .interest-icon {
            color: var(--text-muted);
            flex-shrink: 0;
        }
        .interest-title {
            font-weight: 700;
            font-family: var(--font-mono);
            color: var(--text-main);
            font-size: 1.05rem;
            letter-spacing: 0.02em;
        }

        .tags-wrapper {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        /* --- tag: works.astro の .work-tag と同思想（角型 mono）--- */
        .interest-tag {
            font-family: var(--font-mono), var(--font-sans);
            font-size: 0.78rem;
            line-height: 1.4;
            padding: 0.18rem 0.55rem;
            border: 1px solid var(--border-color);
            border-radius: 0;
            background: var(--background);
            color: var(--text-muted);
            transition:
                color 0.2s ease,
                border-color 0.2s ease;
        }
        @media (hover: hover) {
            .interest-tag:hover {
                color: var(--accent-blue);
                border-color: var(--accent-blue);
            }
        }

        /* === 7. Timeline (git log --graph 風) === */
        .timeline {
            margin: 2rem 0 3rem;
            padding-left: 0.2rem;
            font-family: var(--font-mono);
        }
        .git-line {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-bottom: 1.2rem;
            user-select: none;
        }
        .git-dollar {
            color: var(--accent-blue);
            opacity: 0.8;
            margin-right: 0.4rem;
        }

        /* 縦線（グラフ）= リスト左の border */
        .timeline {
            border-left: 1px solid var(--border-color);
            margin-left: 0.35rem;
        }
        .git-row {
            position: relative;
            display: grid;
            grid-template-columns: auto 1fr;
            column-gap: 0.85rem;
            align-items: baseline;
            padding: 0.55rem 0 0.55rem 1.4rem;
        }
        /* ノード（* 印）を縦線の上に乗せる */
        .git-row::before {
            content: "*";
            position: absolute;
            left: 0;
            top: 0.5rem;
            transform: translateX(-50%);
            color: var(--accent-blue);
            background: var(--background);
            font-weight: 700;
            line-height: 1;
            padding: 0.15rem 0;
        }
        .git-date {
            color: var(--accent-blue);
            font-size: 0.9rem;
            font-weight: 700;
            white-space: nowrap;
        }
        .git-msg {
            color: var(--text-main);
            font-family: var(--font-mono), var(--font-sans);
            font-size: 0.92rem;
            transition: color 0.2s ease;
        }
        @media (hover: hover) {
            .git-row:hover .git-msg {
                color: var(--accent-blue);
            }
        }

        /* === Environments (dotfile / terminal) === */
        .environments {
            margin: 2rem 0 3rem;
            --env-key-w: 8rem;
        }

        .env-terminal {
            background: var(--surface);
            border: 1px solid var(--border-color);
            border-radius: 4px;
            padding: 1.25rem 1.25rem 1.4rem;
            font-family: var(--font-mono);
            font-size: 0.92rem;
            line-height: 1.7;
            overflow-x: auto;
        }

        .env-dollar {
            color: var(--accent-blue);
            opacity: 0.8;
            margin-right: 0.6rem;
            user-select: none;
        }
        .env-promptline {
            color: var(--text-main);
            margin-bottom: 1rem;
        }

        /* ini blocks */
        .env-block {
            margin-bottom: 1.2rem;
        }
        .env-block:last-of-type {
            margin-bottom: 0;
        }
        .env-section-head {
            margin: 0.2rem 0 0.3rem;
        }
        .env-bracket {
            color: var(--accent-blue);
            opacity: 0.5;
        }
        .env-section {
            color: var(--accent-blue);
            font-weight: 700;
        }
        .env-comment {
            color: var(--text-muted);
            margin-left: 0.8rem;
            font-size: 0.85em;
        }

        /* key = value */
        .env-row {
            display: grid;
            grid-template-columns: var(--env-key-w) 1ch 1fr;
            column-gap: 0.6rem;
            align-items: baseline;
            padding: 0.1rem 0.5rem;
            margin: 0 -0.5rem;
            border-radius: 4px;
            transition: background-color 0.15s ease;
        }
        .env-k {
            color: var(--text-muted);
            white-space: nowrap;
        }
        .env-eq {
            color: var(--text-muted);
            opacity: 0.6;
        }
        .env-v {
            color: var(--text-main);
            /* 英数字は mono、日本語は sans にフォールバック */
            font-family: var(--font-mono), var(--font-sans);
            word-break: break-word;
        }

        /* follow-up command links */
        .env-links {
            margin-top: 1.3rem;
            padding-top: 1rem;
            border-top: 1px dashed var(--border-color);
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }
        .env-cmd {
            display: flex;
            align-items: baseline;
            text-decoration: none;
            color: var(--text-main);
            padding: 0.25rem 0.5rem;
            margin: 0 -0.5rem;
            border-radius: 4px;
            transition:
                background-color 0.15s ease,
                color 0.15s ease;
        }

        .env-cmd--inline {
            margin-top: 0.6rem;
        }
        .env-tag {
            margin-left: 0.8rem;
        }
        .env-arrow {
            margin-left: 0.5rem;
            color: var(--accent-blue);
            transform: translateX(-4px);
            opacity: 0;
            transition:
                transform 0.2s ease,
                opacity 0.2s ease;
        }

        /* hover: pointer devices only */
        @media (hover: hover) {
            .env-row:hover {
                background-color: color-mix(
                    in srgb,
                    var(--accent-blue) 10%,
                    transparent
                );
            }
            .env-row:hover .env-k {
                color: var(--accent-blue);
            }
            .env-cmd:hover {
                background-color: color-mix(
                    in srgb,
                    var(--accent-blue) 10%,
                    transparent
                );
            }
            .env-cmd:hover .env-cmd-text {
                color: var(--accent-blue);
            }
            .env-cmd:hover .env-arrow {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* reveal (一度だけ発火 / IntersectionObserver 方式) */
        .env-terminal .env-line {
            transition:
                opacity 0.4s ease,
                transform 0.4s ease;
        }
        .env-terminal.reveal-ready:not(.is-revealed) .env-line {
            opacity: 0;
            transform: translateX(-8px);
        }

        @media (prefers-reduced-motion: reduce) {
            .env-terminal .env-line {
                opacity: 1 !important;
                transform: none !important;
                transition: none !important;
            }
        }

        /* === レスポンシブ === */
        @media (max-width: 768px) {
            .skill-grid {
                gap: 0.8rem;
            }
            .skill-card {
                width: 80px;
                height: 80px;
            }
            .icon-wrapper {
                width: 42px;
                height: 42px;
            }

            .environments {
                --env-key-w: 6.5rem;
            }
            .env-terminal {
                font-size: 0.82rem;
                padding: 1rem;
            }
            .env-comment {
                display: block;
                margin-left: 0;
            }
            .env-cmd {
                flex-wrap: wrap;
            }
        }
    </style>
</Layout>
