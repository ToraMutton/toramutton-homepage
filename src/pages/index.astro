                    <a href="/blog" class="view-all">すべての記事を見る →</a>
                </div>
                <!-- marquee outer: overflow hidden でスクロールバー完全非表示 -->
                <div class="marquee-outer">
                    <div class="marquee-track" id="marquee-track">
                        {
                            latestPosts.map((post) => (
                                <a
                                    href={post.url}
                                    class="post-card-mini"
                                    target={
                                        post.source !== "local"
                                            ? "_blank"
                                            : "_self"
                                    }
                                    rel={
                                        post.source !== "local"
                                            ? "noopener noreferrer"
                                            : undefined
                                    }
                                >
                                    <div class="post-thumb">
                                        {post.source === "local" &&
                                        typeof post.image === "object" ? (
                                            <Image src={post.image} alt="" />
                                        ) : post.image &&
                                          typeof post.image === "string" ? (
                                            <img
                                                src={post.image}
                                                alt=""
                                                loading="lazy"
                                            />
                                        ) : (
                                            <div class="no-image-placeholder">
                                                No Image
                                            </div>
                                        )}
                                        <span
                                            class={`badge badge-${post.source}`}
                                        >
                                            {post.source.toUpperCase()}
                                        </span>
                                    </div>
                                    <div class="post-info">
                                        <time
                                            datetime={post.date.toISOString()}
                                        >
                                            {post.date.toLocaleDateString(
                                                "ja-JP",
                                                {
                                                    year: "numeric",
                                                    month: "2-digit",
                                                    day: "2-digit",
                                                },
                                            )}
                                        </time>
                                        <h3 class="post-title">{post.title}</h3>
                                    </div>
                                </a>
                            ))
                        }
                    </div>
                </div>
            </section>

            <script
                id="terminal-commands-data"
                type="application/json"
                set:html={JSON.stringify(terminalCommands)}
            />

            <div class="grid-container">
                <!-- Mini Terminal -->
                <div
                    class="widget-card mini-terminal-card"
                    data-reveal
                    data-mini-terminal
                >
                    <div class="card-header">
                        <span class="mini-terminal-dots" id="mt-dots">
                            <i
                                data-mt-dot="red"
                                role="button"
                                tabindex="0"
                                aria-label="reroll"></i>
                            <i
                                data-mt-dot="yellow"
                                role="button"
                                tabindex="0"
                                aria-label="reroll"></i>
                            <i
                                data-mt-dot="green"
                                role="button"
                                tabindex="0"
                                aria-label="reroll"></i>
                        </span>
                        <span class="mini-terminal-title">~/toramutton</span>
                    </div>
                    <div
                        class="card-body mini-terminal-body"
                        id="mini-terminal-body"
                    >
                        {
                            selectedCommands.map((c, i) => (
                                <div
                                    class="mt-block"
                                    data-cmd={c.cmd}
                                    data-out={c.out}
                                    data-index={i}
                                >
                                    <p class="mt-line">
                                        <span class="mt-prompt">$</span>
                                        <span class="mt-cmd" />
                                    </p>
                                    <p class="mt-out" />
                                </div>
                            ))
                        }
                        <p class="mt-line mt-cursor-line">
                            <span class="mt-prompt">$</span>
                            <span class="mt-cursor" id="mt-cursor">▌</span>
                        </p>
                    </div>
                </div>

                <!-- GitHub Contributions -->
                <div class="widget-card gh-card" data-reveal>
                    <div class="card-header">
                        <GitGraph class="icon-blue" size={16} />
                        <h3>GitHub Contributions</h3>
                        <span class="gh-total">{ghTotal} / yr</span>
                    </div>
                    <div class="card-body">
                        <div class="gh-grid" id="gh-grid">
                            {
                                recentContributions.map((day) => (
                                    <div
                                        class={`gh-cell gh-level-${day.level}`}
                                        title={`${day.date}: ${day.count}`}
                                    />
                                ))
                            }
                        </div>
                        <div class="gh-legend">
                            <span class="gh-legend-label">Less</span>
                            <div class="gh-cell gh-level-0"></div>
                            <div class="gh-cell gh-level-1"></div>
                            <div class="gh-cell gh-level-2"></div>
                            <div class="gh-cell gh-level-3"></div>
                            <div class="gh-cell gh-level-4"></div>
                            <span class="gh-legend-label">More</span>
                        </div>
                        <div class="dedicated-link">
                            <a
                                href="https://github.com/toramutton"
                                target="_blank"
                                rel="noopener noreferrer"
                                >View GitHub Profile →
                            </a>
                        </div>
                    </div>
                </div>

                <!-- My Desktop PC -->
                <div class="widget-card project-card" data-reveal>
                    <div class="card-header">
                        <Cpu class="icon-blue" size={16} />
                        <h3>My Desktop PC</h3>
                    </div>
                    <div class="card-body">
                        <p class="card-desc">
                            Ryzen 7 7700 + Radeon RX 9060 XT 16GB 構成。
                            2026/02/13~
                        </p>
                        <div class="dedicated-link">
                            <a href="/about#trapezium">View Details →</a>
                        </div>
                    </div>
                </div>

                <!-- Countdown -->
                <div class="widget-card mission-card" data-reveal>
                    <div class="card-header">
                        <Target class="icon-blue" size={16} />
                        <h3>Countdown</h3>
                    </div>
                    <div class="card-body">
                        <div class="mission-list">
                            {
                                missionData.map((m) => (
                                    <div
                                        class="mission-item js-mission-item"
                                        data-date={m.date}
                                    >
                                        <div class="mission-info">
                                            <span class="mission-icon">
                                                <m.icon
                                                    size={16}
                                                    strokeWidth={2}
                                                />
                                            </span>
                                            <span class="mission-title">
                                                {m.title}
                                            </span>
                                        </div>
                                        <div class="mission-days">
                                            <span class="days-num js-days-num">
                                                {m.days}
                                            </span>
                                            <span class="days-unit">days</span>
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                </div>

                <!-- Uptime -->
                <div class="widget-card uptime-card" data-reveal>
                    <div class="card-header">
                        <Timer class="icon-blue" size={16} />
                        <h3>Uptime</h3>
                    </div>
                    <div class="card-body">
                        <div class="uptime-list">
                            <div class="uptime-item">
                                <div class="uptime-label">
                                    <Cake size={14} class="uptime-icon" /> 生まれてから
                                </div>
                                <div class="uptime-value">
                                    <span class="uptime-num" id="uptime-birth"
                                        >--</span
                                    >
                                    <span class="uptime-unit">days</span>
                                </div>
                                <div class="uptime-date">since 2006/06/20</div>
                            </div>
                            <div class="uptime-item">
                                <div class="uptime-label">
                                    <Rocket size={14} class="uptime-icon" /> このサイトができてから
                                </div>
                                <div class="uptime-value">
                                    <span class="uptime-num" id="uptime-site"
                                        >--</span
                                    >
                                    <span class="uptime-unit">days</span>
                                </div>
                                <div class="uptime-date">since 2026/01/02</div>
                            </div>
                        </div>
                        <div class="uptime-clock" id="uptime-clock"></div>
                    </div>
                </div>

                <!-- Advent 2026 -->
                <div class="widget-card advent-card" data-reveal>
                    <div class="card-header">
                        <Sparkles class="icon-blue" size={16} />
                        <h3>Advent 2026</h3>
                    </div>
                    <div class="card-body">
                        <p class="card-desc">
                            一人アドベントカレンダー2026開催予定地
                        </p>
                        <div class="dedicated-link">
                            <a href="/advent2026/">View Calendar →</a>
                        </div>
                    </div>
                </div>

                <!-- Links -->
                <div class="widget-card links-card" data-reveal>
                    <div class="card-header">
                        <Users class="icon-secondary" size={16} />
                        <h3>Links</h3>
                    </div>
                    <ul class="link-row-list">
                        {
                            friendLinks.map((link) => (
                                <li class="link-row">
                                    <a
                                        href={link.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="link-row-anchor"
                                    >
                                        <span class="link-row-prompt">▸</span>
                                        <span class="link-row-name">
                                            {link.name}
                                        </span>
                                        <span class="link-row-arrow">↗</span>
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>

            <!-- Today's Music -->
            <div class="widget-card recommendation-card" data-reveal>
                <div class="card-header">
                    <Music class="icon-secondary" size={16} />
                    <h3>Today's Music</h3>
                </div>
                <div id="song-display" class="song-container">
                    <p class="song-cmd-line" id="song-cmd-line">
                        <span class="song-cmd-prompt">$</span><span
                            id="song-cmd-text"></span>
                    </p>
                    <p class="song-title" id="song-title">
                        <span id="song-title-text"></span><span
                            class="song-cursor"
                            id="song-cursor"></span>
                    </p>
                    <p class="song-year-wrapper" id="song-year-wrapper">
                        released in <span id="song-year" class="song-year"
                            >----</span
                        >
                    </p>
                </div>
                <button id="next-song-btn" class="secondary-btn">
                    reload →
                </button>
            </div>

            <!-- Uptime counter script -->
            <script>
                import { songs } from "../data/songs";

                let uptimeTimer: ReturnType<typeof setInterval> | null = null;

                document.addEventListener("astro:page-load", () => {
                    // ★ タイマー管理を一番上に移動
                    let mtTimers: ReturnType<typeof setTimeout>[] = [];
                    const addMtTimer = (fn: () => void, ms: number) => {
                        mtTimers.push(setTimeout(fn, ms));
                    };
                    const clearMtTimers = () => {
                        mtTimers.forEach(clearTimeout);
                        mtTimers = [];
                    };

                    let musicTimers: ReturnType<typeof setTimeout>[] = [];
                    const addMusicTimer = (fn: () => void, ms: number) => {
                        musicTimers.push(setTimeout(fn, ms));
                    };
                    const clearMusicTimers = () => {
                        musicTimers.forEach(clearTimeout);
                        musicTimers = [];
                    };

                    const hero =
                        document.querySelector<HTMLElement>("[data-hero]");
                    if (hero) {
                        const trigger = () =>
                            requestAnimationFrame(() =>
                                hero.setAttribute("data-loaded", ""),
                            );
                        document.fonts?.ready
                            ? document.fonts.ready.then(trigger)
                            : trigger();
                    }

                    // ---- Terminal dots easter egg ----
                    const terminal =
                        document.querySelector<HTMLElement>(".terminal");
                    const termBody =
                        terminal?.querySelector<HTMLElement>(".terminal-body");

                    terminal
                        ?.querySelectorAll<HTMLElement>("i[data-dot]")
                        .forEach((dot) => {
                            dot.addEventListener("click", () => {
                                if (terminal.classList.contains("is-busy"))
                                    return;
                                const kind = dot.dataset.dot;
                                if (kind === "red")
                                    exitDot(terminal, termBody!);
                                if (kind === "yellow") minimizeDot(terminal);
                                if (kind === "green") maxDot(termBody!);
                            });
                        });

                    function exitDot(
                        terminal: HTMLElement,
                        termBody: HTMLElement,
                    ) {
                        terminal.classList.add("is-busy");
                        const saved = termBody.innerHTML;

                        const exitLine = document.createElement("p");
                        exitLine.className = "line";
                        exitLine.innerHTML = `<span class="prompt">$</span><span class="cmd"> exit 0</span>`;
                        termBody.appendChild(exitLine);

                        setTimeout(() => {
                            termBody.style.cssText =
                                "opacity:0; transition:opacity 0.3s ease";
                            setTimeout(() => {
                                termBody.innerHTML = `
                        <p class="line"><span class="comment"># Connection closed.</span></p>
                        <p class="line"><span class="comment"># Rebooting...</span></p>
                    `;
                                termBody.style.cssText =
                                    "opacity:1; transition:opacity 0.3s ease";
                                setTimeout(() => {
                                    termBody.style.cssText =
                                        "opacity:0; transition:opacity 0.3s ease";
                                    setTimeout(() => {
                                        termBody.innerHTML = saved;
                                        termBody.style.cssText = "";
                                        terminal.classList.remove("is-busy");
                                        const hero =
                                            document.querySelector(
                                                "[data-hero]",
                                            );
                                        hero?.removeAttribute("data-loaded");
                                        requestAnimationFrame(() =>
                                            hero?.setAttribute(
                                                "data-loaded",
                                                "",
                                            ),
                                        );
                                    }, 320);
                                }, 1200);
                            }, 350);
                        }, 600);
                    }

                    function minimizeDot(terminal: HTMLElement) {
                        terminal.classList.add("is-minimizing", "is-busy");
                        setTimeout(() => {
                            terminal.classList.remove("is-minimizing");
                            setTimeout(
                                () => terminal.classList.remove("is-busy"),
                                350,
                            );
                        }, 580);
                    }

                    function maxDot(termBody: HTMLElement) {
                        const msg = document.createElement("p");
                        msg.className = "line line-comment";
                        msg.innerHTML = `<span class="comment"># nothing to maximize here :)</span>`;
                        termBody.appendChild(msg);
                        setTimeout(() => {
                            msg.style.cssText =
                                "opacity:0; transition:opacity 0.3s ease";
                            setTimeout(() => msg.remove(), 320);
                        }, 1500);
                    }

                    // カウントダウン処理
                    const missionItems =
                        document.querySelectorAll<HTMLElement>(
                            ".js-mission-item",
                        );
                    const now = new Date();
                    now.setHours(0, 0, 0, 0);

                    missionItems.forEach((item) => {
                        const targetDateStr = item.dataset.date;
                        if (!targetDateStr) return;

                        const target = new Date(targetDateStr);
                        target.setHours(0, 0, 0, 0);

                        const diff = target.getTime() - now.getTime();
                        const days = Math.ceil(diff / (1000 * 60 * 60 * 24));

                        const numEl =
                            item.querySelector<HTMLElement>(".js-days-num");
                        if (numEl) {
                            numEl.innerText = days.toString();
                        }
                    });

                    const titleEl = document.getElementById("song-title");
                    const yearEl = document.getElementById("song-year");
                    const btn = document.getElementById("next-song-btn");

                    // ---- marquee ----
                    const track = document.getElementById("marquee-track");
                    if (track && window.innerWidth > 1024) {
                        const original = track.innerHTML;
                        track.innerHTML = original + original;
                    }

                    // ---- widget-card stagger reveal ----
                    const revealCards =
                        document.querySelectorAll<HTMLElement>("[data-reveal]");
                    const revealObserver = new IntersectionObserver(
                        (entries) => {
                            entries.forEach((entry) => {
                                if (entry.isIntersecting) {
                                    const el = entry.target as HTMLElement;
                                    const delay = el.dataset.revealDelay ?? "0";
                                    el.style.transitionDelay = `${delay}ms`;
                                    el.classList.add("is-visible");
                                    revealObserver.unobserve(el);
                                }
                            });
                        },
                        { threshold: 0.12 },
                    );

                    // ====================================
                    // Mini Terminal
                    // ====================================
                    const miniTermCard = document.querySelector<HTMLElement>(
                        "[data-mini-terminal]",
                    );
                    const mtBody =
                        document.getElementById("mini-terminal-body");

                    const allCommands: { cmd: string; out: string }[] =
                        JSON.parse(
                            document.getElementById("terminal-commands-data")
                                ?.textContent ?? "[]",
                        );

                    let currentCommands: { cmd: string; out: string }[] =
                        Array.from(
                            mtBody?.querySelectorAll<HTMLElement>(
                                ".mt-block",
                            ) ?? [],
                        ).map((b) => ({
                            cmd: b.dataset.cmd ?? "",
                            out: b.dataset.out ?? "",
                        }));

                    function renderMiniTerminal() {
                        if (!mtBody) return;
                        const blocksHTML = currentCommands
                            .map(
                                () => `
                    <div class="mt-block">
                        <p class="mt-line">
                            <span class="mt-prompt">$</span>
                            <span class="mt-cmd"></span>
                        </p>
                        <p class="mt-out"></p>
                    </div>`,
                            )
                            .join("");
                        mtBody.innerHTML =
                            blocksHTML +
                            `<p class="mt-line mt-cursor-line">
                    <span class="mt-prompt">$</span>
                    <span class="mt-cursor" id="mt-cursor">▌</span>
                </p>`;
                    }

                    function typeMiniTerminal() {
                        if (!mtBody) return;
                        const blocks =
                            mtBody.querySelectorAll<HTMLElement>(".mt-block");
                        const cursor =
                            mtBody.querySelector<HTMLElement>("#mt-cursor");
                        let blockDelay = 0;

                        blocks.forEach((block, idx) => {
                            const { cmd, out } = currentCommands[idx];
                            const cmdEl =
                                block.querySelector<HTMLElement>(".mt-cmd");
                            const outEl =
                                block.querySelector<HTMLElement>(".mt-out");
                            if (!cmdEl || !outEl) return;

                            const startDelay = blockDelay;
                            // ★ 全て addMtTimer に修正済み
                            addMtTimer(() => {
                                let charIndex = 0;
                                const typeChar = () => {
                                    if (charIndex < cmd.length) {
                                        cmdEl.textContent = cmd.slice(
                                            0,
                                            ++charIndex,
                                        );
                                        addMtTimer(typeChar, 38);
                                    } else {
                                        outEl.textContent = out;
                                        addMtTimer(
                                            () =>
                                                outEl.classList.add(
                                                    "is-visible",
                                                ),
                                            80,
                                        );
                                    }
                                };
                                typeChar();
                            }, startDelay);

                            blockDelay += cmd.length * 38 + 80 + 300;
                        });

                        addMtTimer(() => {
                            if (cursor) cursor.style.opacity = "1";
                        }, blockDelay);
                    }

                    function pickNewCommands() {
                        const currentCmds = currentCommands.map((c) => c.cmd);
                        const pool = allCommands.filter(
                            (c) => !currentCmds.includes(c.cmd),
                        );
                        const source = pool.length >= 3 ? pool : allCommands;
                        currentCommands = [...source]
                            .sort(() => Math.random() - 0.5)
                            .slice(0, 3);
                    }

                    function rerollMiniTerminal() {
                        pickNewCommands();
                        renderMiniTerminal();
                        typeMiniTerminal();
                    }

                    // ---- ドットクリック演出 ----
                    const mtDotsEl = document.getElementById("mt-dots");
                    const mtCard = document.querySelector<HTMLElement>(
                        ".mini-terminal-card",
                    );

                    mtDotsEl
                        ?.querySelectorAll<HTMLElement>("i[data-mt-dot]")
                        .forEach((dot) => {
                            dot.addEventListener("click", () => {
                                if (mtCard?.classList.contains("mt-busy"))
                                    return;
                                if (!mtBody) return;
                                mtCard?.classList.add("mt-busy");
                                const kind = dot.dataset.mtDot;

                                if (kind === "red") {
                                    const exitLine =
                                        document.createElement("p");
                                    exitLine.className = "mt-line";
                                    exitLine.innerHTML = `<span class="mt-prompt">$</span><span class="mt-cmd"> exit 0</span>`;
                                    mtBody.appendChild(exitLine);

                                    setTimeout(() => {
                                        mtBody.style.cssText =
                                            "opacity:0; transition:opacity 0.3s ease";
                                        setTimeout(() => {
                                            mtBody.innerHTML = `
                                <p class="mt-line"><span class="mt-prompt" style="color:var(--text-muted)">#</span><span class="mt-cmd"> Connection closed.</span></p>
                                <p class="mt-line"><span class="mt-prompt" style="color:var(--text-muted)">#</span><span class="mt-cmd"> Rebooting...</span></p>`;
                                            mtBody.style.cssText =
                                                "opacity:1; transition:opacity 0.3s ease";
                                            setTimeout(() => {
                                                mtBody.style.cssText =
                                                    "opacity:0; transition:opacity 0.3s ease";
                                                setTimeout(() => {
                                                    mtBody.style.cssText = "";
                                                    rerollMiniTerminal();
                                                    mtCard?.classList.remove(
                                                        "mt-busy",
                                                    );
                                                }, 320);
                                            }, 1000);
                                        }, 350);
                                    }, 500);
                                } else if (kind === "yellow") {
                                    mtCard?.classList.add("is-squishing");
                                    setTimeout(() => {
                                        rerollMiniTerminal();
                                        mtCard?.classList.remove(
                                            "is-squishing",
                                        );
                                        setTimeout(
                                            () =>
                                                mtCard?.classList.remove(
                                                    "mt-busy",
                                                ),
                                            350,
                                        );
                                    }, 500);
                                } else if (kind === "green") {
                                    const msg = document.createElement("p");
                                    msg.className = "mt-line";
                                    msg.innerHTML = `<span class="mt-prompt" style="color:var(--text-muted)">#</span><span class="mt-cmd"> re-rolling...</span>`;
                                    mtBody.appendChild(msg);

                                    setTimeout(() => {
                                        msg.style.cssText =
                                            "opacity:0; transition:opacity 0.3s ease";
                                        setTimeout(() => {
                                            rerollMiniTerminal();
                                            mtCard?.classList.remove("mt-busy");
                                        }, 320);
                                    }, 800);
                                }
                            });
                        });

                    if (miniTermCard) {
                        const mtObserver = new IntersectionObserver(
                            (entries) => {
                                entries.forEach((entry) => {
                                    if (entry.isIntersecting) {
                                        addMtTimer(typeMiniTerminal, 300);
                                        mtObserver.unobserve(entry.target);
                                    }
                                });
                            },
                            { threshold: 0.2 },
                        );
                        mtObserver.observe(miniTermCard);
                    }

                    document
                        .querySelectorAll<HTMLElement>(
                            ".grid-container [data-reveal]",
                        )
                        .forEach((el, i) => {
                            el.dataset.revealDelay = String(i * 80);
                            revealObserver.observe(el);
                        });

                    document
                        .querySelectorAll<HTMLElement>(
                            ".recommendation-card[data-reveal]",
                        )
                        .forEach((el) => revealObserver.observe(el));

                    // --- 要素取得を id ベースに切り替え ---
                    const cmdTextEl = document.getElementById("song-cmd-text");
                    const titleTextEl =
                        document.getElementById("song-title-text");
                    const cursorEl = document.getElementById("song-cursor");
                    const yearWrapEl =
                        document.getElementById("song-year-wrapper");

                    const GLITCH_CHARS =
                        "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*<>/\\|";
                    const randChar = () =>
                        GLITCH_CHARS[
                            Math.floor(Math.random() * GLITCH_CHARS.length)
                        ];

                    // タイプライター（コマンド行）
                    function typeCmd(text: string, onDone: () => void) {
                        if (!cmdTextEl) return;
                        cmdTextEl.textContent = "";
                        let i = 0;
                        const tick = () => {
                            if (i >= text.length) {
                                onDone();
                                return;
                            }
                            cmdTextEl.textContent += text[i++];
                            // ★ 全て addMusicTimer に修正済み
                            addMusicTimer(tick, 32);
                        };
                        tick();
                    }

                    // グリッチタイプライター（タイトル行）
                    function glitchType(text: string, onDone: () => void) {
                        if (!titleTextEl) return;
                        titleTextEl.textContent = "";

                        const chars = [...text];
                        let confirmed = 0;

                        const nextChar = () => {
                            if (confirmed >= chars.length) {
                                onDone();
                                return;
                            }

                            const targetChar = chars[confirmed];
                            let glitchCount = 0;
                            const shouldGlitch = /[\p{L}\p{N}]/u.test(
                                targetChar,
                            );
                            const maxGlitch = shouldGlitch ? 3 : 0;

                            const glitchTick = () => {
                                if (glitchCount >= maxGlitch) {
                                    const base = chars
                                        .slice(0, confirmed)
                                        .join("");
                                    titleTextEl.textContent = base + targetChar;
                                    confirmed++;
                                    addMusicTimer(nextChar, 45);
                                } else {
                                    const base = chars
                                        .slice(0, confirmed)
                                        .join("");
                                    titleTextEl.textContent = base + randChar();
                                    glitchCount++;
                                    addMusicTimer(glitchTick, 38);
                                }
                            };
                            glitchTick();
                        };
                        nextChar();
                    }

                    // スロット年号
                    function slotYear(targetYear: string, onDone: () => void) {
                        if (!yearEl) return;
                        const target = parseInt(targetYear, 10);
                        const duration = 900;
                        const start = performance.now();

                        const tick = (now: number) => {
                            const elapsed = now - start;
                            const progress = Math.min(elapsed / duration, 1);
                            const eased = 1 - Math.pow(1 - progress, 3);

                            if (progress < 1) {
                                const display = Math.floor(
                                    Math.random() * 10000,
                                )
                                    .toString()
                                    .padStart(4, "0");
                                yearEl.textContent = display;
                                requestAnimationFrame(tick);
                            } else {
                                yearEl.textContent = targetYear;
                                onDone();
                            }
                        };
                        requestAnimationFrame(tick);
                    }

                    function updateSong() {
                        const randomSong =
                            songs[Math.floor(Math.random() * songs.length)];

                        // ★ clearMusicTimers に修正済み
                        clearMusicTimers();
                        if (cmdTextEl) cmdTextEl.textContent = "";
                        if (titleTextEl) titleTextEl.textContent = "";
                        if (cursorEl) cursorEl.classList.remove("blink");
                        if (yearEl) yearEl.textContent = "----";
                        if (yearWrapEl) yearWrapEl.style.opacity = "0";

                        typeCmd("play --random", () => {
                            addMusicTimer(() => {
                                if (yearWrapEl) {
                                    yearWrapEl.style.transition =
                                        "opacity 0.3s ease";
                                    yearWrapEl.style.opacity = "0.8";
                                }
                                slotYear(randomSong.year, () => {});
                                glitchType(randomSong.title, () => {
                                    if (cursorEl)
                                        cursorEl.classList.add("blink");
                                });
                            }, 150);
                        });
                    }

                    btn?.addEventListener("click", updateSong);
                    updateSong();

                    // ---- Uptime counter ----
                    if (uptimeTimer !== null) clearInterval(uptimeTimer);

                    function updateUptime() {
                        const now = new Date();
                        const birthDays = Math.floor(
                            (now.getTime() -
                                new Date(
                                    "2006-06-20T00:00:00+09:00",
                                ).getTime()) /
                                86400000,
                        );
                        const siteDays = Math.floor(
                            (now.getTime() -
                                new Date(
                                    "2026-01-02T00:00:00+09:00",
                                ).getTime()) /
                                86400000,
                        );
                        const birthEl = document.getElementById("uptime-birth");
                        const siteEl = document.getElementById("uptime-site");
                        const clockEl = document.getElementById("uptime-clock");
                        if (birthEl)
                            birthEl.textContent =
                                birthDays.toLocaleString("ja-JP");
                        if (siteEl)
                            siteEl.textContent =
                                siteDays.toLocaleString("ja-JP");
                        if (clockEl)
                            clockEl.textContent = now.toLocaleString("ja-JP", {
                                timeZone: "Asia/Tokyo",
                                hour: "2-digit",
                                minute: "2-digit",
                                second: "2-digit",
                            });
                    }
                    updateUptime();
                    uptimeTimer = setInterval(updateUptime, 1000);
                });

                // メッセージ
                const style3D = `
        font-weight: 900;
        font-size: 2.5rem;
        color: #bae6fd;
        text-shadow:
            0 1px 0 #0ea5e9,
            0 2px 0 #0284c7,
            0 3px 0 #0369a1,
            0 4px 0 #075985,
            0 5px 0 #0c4a6e,
            0 6px 1px rgba(0,0,0,0.1),
            0 0 5px rgba(0,0,0,0.1),
            0 1px 3px rgba(0,0,0,0.3),
            0 3px 5px rgba(0,0,0,0.2),
            0 5px 10px rgba(0,0,0,0.25),
            0 10px 10px rgba(0,0,0,0.2),
            0 20px 20px rgba(0,0,0,0.15);
    `;

                const styleAA =
                    "font-family: 'Menlo', 'Consolas', monospace; font-weight: bold; color: #38bdf8; line-height: 1.2;";
                const styleBody =
                    "font-family: sans-serif; color: #7dd3fc; font-size: 0.9rem;";

                console.log("%cToraMutton's Homepage", style3D);
                console.log(
                    `%c
 ______                  __  ___      __  __
/_  __/___  ________ _ /  |/  /_  __/ /_/ /_____  ____
 / / / __ \\/ ___/ __ \`/ /|_/ / / / / __/ __/ __ \\/ __ \\
/ / / /_/ / /  / /_/ / /  / / /_/ / /_/ /_/ /_/ / / / /
/_/  \\____/_/   \\__,_/_/  /_/\\__,_/\\__/\\__/\\____/_/ /_/
        `,
                    styleAA,
                );
                console.log(
                    `%c
    🚀 Built with Astro & Vercel.
    -----------------------------------
    Looking for bugs?
    Thanks for visiting!
        `,
                    styleBody,
                );
            </script>

            <Footer />
        </main>
    </body>
</html>

<style>
    /* ====================================
   Hero — terminal-style
   ==================================== */
    .hero {
        padding: 6rem 0 5rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
        gap: 2rem;
        align-items: start;
    }

    /* ---- Terminal block ---- */
    .terminal {
        background: var(--surface);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        overflow: hidden;
        transform-origin: top center;
        transition:
            transform 0.3s cubic-bezier(0, 0, 0.2, 1.4),
            opacity 0.3s ease;
        font-family: "JetBrains Mono", ui-monospace, monospace;
    }

    .terminal.is-minimizing {
        transform: scaleY(0.04);
        opacity: 0;
        pointer-events: none;
    }

    .terminal-avatar {
        position: absolute;
        top: 1.4rem;
        right: 1.2rem;
        z-index: 1;
        opacity: 0;
        transform: scale(0.92);
    }
    .hero[data-loaded] .terminal-avatar {
        opacity: 1;
        transform: scale(1);
        transition:
            opacity 0.45s ease,
            transform 0.45s ease;
        transition-delay: 0.4s;
    }

    .terminal-avatar :global(img) {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        box-shadow: none;
        object-fit: cover;
        display: block;
        border: 1px solid var(--border-color);
    }

    .terminal-header {
        display: flex;
        position: relative;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 1rem;
        background: var(--elevated, rgba(0, 0, 0, 0.06));
        border-bottom: 1px solid var(--border-color);
    }

    :global(html.dark) .terminal-header {
        background: rgba(255, 255, 255, 0.04);
    }

    .terminal-dots {
        display: inline-flex;
        gap: 6px;
    }
    .terminal-dots i {
        display: inline-block;
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: var(--border-color);
        cursor: pointer;
        transition: background 0.15s ease;
    }

    @media (hover: hover) {
        .terminal-dots:hover i[data-dot="red"] {
            background: #ff5f57;
        }
        .terminal-dots:hover i[data-dot="yellow"] {
            background: #ffbd2e;
        }
        .terminal-dots:hover i[data-dot="green"] {
            background: #28c840;
        }
    }

    .terminal-path {
        font-size: 0.75rem;
        color: var(--text-muted);
        letter-spacing: 0.02em;
    }

    .terminal-body {
        position: relative;
        padding: 1.5rem 1.2rem 1.8rem;
        font-size: 0.95rem;
        line-height: 1.7;
        color: var(--text-main);
    }

    .line {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        margin: 0;
        min-height: 1.6em;
    }
    .line-blank {
        min-height: 0.6em;
    }

    .prompt {
        color: var(--accent-blue);
        font-weight: 600;
        flex-shrink: 0;
    }

    .cmd {
        color: var(--text-main);
    }

    .output {
        color: var(--text-main);
        font-weight: 700;
        font-size: 1.15rem;
        padding-left: 1.2rem;
        position: relative;
    }
    .output::before {
        content: ">";
        position: absolute;
        left: 0;
        color: var(--text-muted);
        font-weight: 400;
    }

    .comment {
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    /* ---- Social links ---- */
    .social-links {
        gap: 0.5rem;
        padding-left: 1.2rem;
        margin-top: 0.2rem;
    }

    .social-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.3rem 0.7rem;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        font-size: 0.8rem;
        color: var(--text-muted);
        background: transparent;
        border: 1px solid var(--border-color);
        border-radius: 0;
        text-decoration: none;
        transition:
            color 0.18s ease,
            border-color 0.18s ease;
    }

    @media (hover: hover) {
        .social-btn:hover {
            color: var(--accent-blue);
            border-color: var(--accent-blue);
        }
    }

    /* ---- CTA (cd ./about) ---- */
    .cmd-link {
        color: var(--text-main);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: color 0.18s ease;
    }
    .cursor-arrow {
        color: var(--accent-blue);
        transition: transform 0.18s ease;
    }
    @media (hover: hover) {
        .cmd-link:hover {
            color: var(--accent-blue);
        }
        .cmd-link:hover .cursor-arrow {
            transform: translateX(4px);
        }
    }

    /* ---- Spec block (右カラム) ---- */
    .spec-block {
        font-family: "JetBrains Mono", ui-monospace, monospace;
        padding-top: 0.6rem;
    }
    .spec-block-title {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0 0 1rem;
        letter-spacing: 0.05em;
    }
    .spec-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .spec-list li {
        display: grid;
        grid-template-columns: 70px 1fr;
        gap: 1rem;
        padding: 0.55rem 0;
        border-bottom: 1px dashed var(--border-color);
        align-items: baseline;
    }
    .spec-list li:last-child {
        border-bottom: none;
    }
    .spec-key {
        font-size: 0.72rem;
        color: var(--accent-blue);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .spec-val {
        font-size: 0.9rem;
        color: var(--text-main);
    }
    .spec-val-live {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }
    .dot-live {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent-blue);
        box-shadow: 0 0 6px var(--accent-blue);
        animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0.4;
        }
    }

    /* ====================================
   Load animations
   ==================================== */
    .line,
    .spec-block {
        opacity: 0;
        transform: translateY(8px);
    }

    .hero[data-loaded] .line,
    .hero[data-loaded] .spec-block {
        opacity: 1;
        transform: translateY(0);
        transition:
            opacity 0.45s ease,
            transform 0.45s ease;
        transition-delay: calc(0.6s + var(--i, 0) * 90ms);
    }

    /* whoami 行は即表示（タイプライターが担当） */
    .hero[data-loaded] .line[style*="--i: 0"] {
        opacity: 1;
        transform: translateY(0);
        transition-delay: 0s;
    }

    /* タイプライター */
    .typewriter {
        display: inline-block;
        overflow: hidden;
        white-space: nowrap;
        vertical-align: bottom;
        max-width: 0;
        border-right: 2px solid var(--accent-blue);
    }
    .hero[data-loaded] .typewriter {
        animation:
            typing 0.6s steps(6, end) 0.15s forwards,
            caret 0.7s step-end 3 0.75s;
    }
    @keyframes typing {
        to {
            max-width: 7ch;
        }
    }
    @keyframes caret {
        50% {
            border-color: transparent;
        }
    }

    /* ====================================
   Reduced motion
   ==================================== */
    @media (prefers-reduced-motion: reduce) {
        .line,
        .spec-block {
            opacity: 1;
            transform: none;
            transition: none;
        }
        .hero[data-loaded] .line,
        .hero[data-loaded] .spec-block {
            transition: none;
            transition-delay: 0s;
        }
        .typewriter {
            max-width: none;
            border-right: none;
            animation: none;
        }
        .dot-live {
            animation: none;
        }
        .terminal-avatar {
            opacity: 1;
            transform: none;
            transition: none;
        }
    }

    /* ====================================
   Mobile (≤ 720px) — Hero
   ==================================== */
    @media (max-width: 720px) {
        .hero {
            padding: 4rem 0 3rem;
        }
        .hero-grid {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }
        .terminal-body {
            padding: 1.2rem 1rem 1.4rem;
            font-size: 0.88rem;
        }
        .output {
            font-size: 1.05rem;
        }
        .social-links {
            padding-left: 0;
            flex-wrap: wrap;
        }
        .spec-list li {
            grid-template-columns: 60px 1fr;
            gap: 0.6rem;
        }
    }

    /* ====================================
       3. 最新の記事 — marquee
       ==================================== */
    .recent-posts {
        margin: 4rem 0;
    }

    .section-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .section-header h2 {
        margin: 0;
        font-size: 1.5rem;
    }

    /* view-all: glass 廃止 → flat border リンク */
    .view-all {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.45rem 0.9rem;
        font-size: 0.82rem;
        font-family: var(--font-mono);
        border: 1px solid var(--border-color);
        border-radius: 0;
        transition:
            color 0.18s ease,
            border-color 0.18s ease;
        white-space: nowrap;
    }

    @media (hover: hover) {
        .view-all:hover {
            color: var(--accent-blue);
            border-color: var(--accent-blue);
        }
    }

    /* ---- marquee wrapper ---- */
    .marquee-outer {
        overflow: hidden; /* スクロールバー完全非表示 */
        /* 左右に fade mask */
        -webkit-mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 6%,
            black 94%,
            transparent 100%
        );
        mask-image: linear-gradient(
            to right,
            transparent 0%,
            black 6%,
            black 94%,
            transparent 100%
        );
    }

    .marquee-track {
        display: flex;
        gap: 1.25rem;
        width: max-content;
        animation: marquee-scroll 28s linear infinite;
        will-change: transform;
    }

    /* hover / touch: pause */
    .marquee-outer:hover .marquee-track,
    .marquee-outer:focus-within .marquee-track {
        animation-play-state: paused;
    }

    @keyframes marquee-scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    /* prefers-reduced-motion: 静止 */
    @media (prefers-reduced-motion: reduce) {
        .marquee-track {
            animation: none;
        }
        .marquee-outer {
            overflow-x: auto;
            scrollbar-width: none;
            -webkit-mask-image: none;
            mask-image: none;
        }
        .marquee-outer::-webkit-scrollbar {
            display: none;
        }
    }

    /* ---- post-card-mini: de-glass ---- */
    .post-card-mini {
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        width: 280px;
        background: var(--surface);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        overflow: hidden;
        text-decoration: none;
        color: var(--text-main);
        position: relative;
    }

    /* サムネ上の斜め clip-path ワイプ（yui540 演出）*/
    .post-thumb::after {
        content: "";
        position: absolute;
        inset: 0;
        background: var(--accent-blue);
        opacity: 0.18;
        clip-path: polygon(0 0, 0 0, 0 100%, 0 100%);
        transition: clip-path 0.42s cubic-bezier(0.4, 0, 0.2, 1);
        pointer-events: none;
        z-index: 1;
    }

    @media (hover: hover) {
        .post-card-mini:hover .post-thumb::after {
            clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
        }

        /* 画像ズーム */
        .post-card-mini:hover .post-thumb img {
            transform: scale(1.05);
        }

        /* タイトル accent */
        .post-card-mini:hover .post-title {
            color: var(--accent-blue);
        }
    }

    .post-thumb {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        background: var(--elevated);
        overflow: hidden;
    }

    .post-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.42s ease;
        display: block;
    }

    .no-image-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--elevated);
        color: var(--text-muted);
        font-size: 0.75rem;
        font-family: var(--font-mono);
    }

    .badge {
        position: absolute;
        top: 8px;
        right: 8px;
        padding: 2px 7px;
        font-size: 0.6rem;
        font-weight: 700;
        font-family: var(--font-mono);
        color: #fff;
        border-radius: 0;
        letter-spacing: 0.06em;
        z-index: 2;
    }

    .badge-local {
        background: #2563eb;
    }
    .badge-note {
        background: #2dbb9f;
    }
    .badge-zenn {
        background: #3ea8ff;
    }
    .badge-qiita {
        background: #55c500;
    }

    .post-info {
        padding: 0.85rem 1rem;
    }

    .post-info time {
        font-size: 0.75rem;
        color: var(--text-muted);
        font-family: var(--font-mono);
        display: block;
        margin-bottom: 0.3rem;
    }

    .post-title {
        font-size: 0.92rem;
        margin: 0;
        line-height: 1.5;
        font-weight: 600;
        font-family: var(--font-mono);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 0.18s ease;
    }

    /* ====================================
       4. widget-card — border-card ベース
       ==================================== */
    .grid-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        margin: 3rem 0;
    }

    /* stagger reveal: JS で .is-visible を付与 */
    .widget-card {
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        overflow: hidden; /* header の border-bottom が角から溢れないよう */

        opacity: 0;
        transform: translateY(16px);
        transition:
            opacity 0.45s ease,
            transform 0.45s ease;
    }

    .widget-card.is-visible {
        opacity: 1;
        transform: translateY(0);
    }

    /* カードヘッダー: terminal-header と同じ tone */
    .card-header {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.75rem 1.25rem;
        border-bottom: 1px solid var(--border-color);
        background: var(--elevated);
        flex-shrink: 0;
    }

    .card-header h3 {
        margin: 0;
        font-size: 0.88rem;
        font-family: var(--font-mono);
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    /* カードボディ共通 padding */
    .card-body {
        padding: 1.25rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .card-desc {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.7;
        flex-grow: 1;
        margin: 0;
    }

    .icon-blue {
        color: var(--accent-blue);
    }
    .icon-secondary {
        color: var(--accent-blue);
    }

    /* ====================================
       4.5 Mini Terminal カード
       ==================================== */
    .mini-terminal-card {
        font-family: var(--font-mono);
        transform-origin: top center;
        transition:
            transform 0.3s cubic-bezier(0, 0, 0.2, 1.4),
            opacity 0.3s ease;
    }

    .mini-terminal-dots {
        display: inline-flex;
        gap: 5px;
    }
    .mini-terminal-dots i {
        display: inline-block;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--border-color);
        cursor: pointer;
        transition: background 0.15s ease;
    }

    @media (hover: hover) {
        .mini-terminal-dots:hover i[data-mt-dot="red"] {
            background: #ff5f57;
        }
        .mini-terminal-dots:hover i[data-mt-dot="yellow"] {
            background: #ffbd2e;
        }
        .mini-terminal-dots:hover i[data-mt-dot="green"] {
            background: #28c840;
        }
    }

    /* squish アニメ（黄） */
    .mini-terminal-card.is-squishing {
        transform: scaleY(0.04);
        opacity: 0;
        pointer-events: none;
    }

    .mini-terminal-title {
        font-size: 0.72rem;
        color: var(--text-muted);
        letter-spacing: 0.02em;
    }

    .mini-terminal-body {
        gap: 0;
        padding: 1rem 1.25rem 1.25rem;
    }

    .mini-terminal-body :global(.mt-block) {
        margin-bottom: 0.6rem;
    }

    .mini-terminal-body :global(.mt-block:last-of-type) {
        margin-bottom: 0.4rem;
    }

    .mini-terminal-body :global(.mt-line) {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin: 0;
        min-height: 1.5em;
        font-size: 0.88rem;
    }

    .mini-terminal-body :global(.mt-cursor-line) {
        margin-top: 0.2rem;
    }

    .mini-terminal-body :global(.mt-prompt) {
        color: var(--accent-blue);
        font-weight: 600;
        flex-shrink: 0;
    }

    .mini-terminal-body :global(.mt-cmd) {
        color: var(--text-main);
        font-size: 0.88rem;
    }

    .mini-terminal-body :global(.mt-out) {
        color: var(--accent-blue);
        font-size: 0.85rem;
        padding-left: 1.2rem;
        margin: 0.1rem 0 0;
        min-height: 1.4em;
        opacity: 0;
        transform: translateY(3px);
        transition:
            opacity 0.25s ease,
            transform 0.25s ease;
    }

    .mini-terminal-body :global(.mt-out.is-visible) {
        opacity: 1;
        transform: translateY(0);
    }

    .mini-terminal-body :global(.mt-cursor) {
        color: var(--accent-blue);
        font-size: 0.9rem;
        animation: mt-blink 1s step-end infinite;
        opacity: 0; /* JS で表示 */
    }

    @keyframes mt-blink {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .mt-cursor {
            animation: none;
            opacity: 1;
        }
        .mt-out {
            opacity: 1;
            transform: none;
            transition: none;
        }
    }

    /* ====================================
       5. Countdown カード
       ==================================== */
    .mission-list {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .mission-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.65rem 0;
        border-bottom: 1px dashed var(--border-color);
    }

    .mission-item:last-child {
        border-bottom: none;
    }

    .mission-info {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .mission-icon {
        color: var(--text-muted);
        flex-shrink: 0;
    }

    .mission-title {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-main);
    }

    .mission-days {
        display: flex;
        align-items: baseline;
        gap: 0.25rem;
        font-family: var(--font-mono);
        flex-shrink: 0;
    }

    .days-num {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--accent-blue);
    }

    .days-unit {
        font-size: 0.65rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* ====================================
       6. dedicated-link / coming-soon
       ==================================== */
    .dedicated-link {
        margin-top: auto;
    }

    .dedicated-link a {
        display: block;
        padding: 0.55rem 1rem;
        border: 1px solid var(--border-color);
        text-align: center;
        font-size: 0.72rem;
        font-family: var(--font-mono);
        font-weight: 700;
        color: var(--accent-blue);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-decoration: none;
        border-radius: 0;
        transition:
            border-color 0.18s ease,
            background 0.18s ease;
    }

    @media (hover: hover) {
        .dedicated-link a:hover {
            border-color: var(--accent-blue);
            background: rgba(34, 211, 238, 0.06);
        }
    }

    .coming-soon-badge {
        margin-top: 1.25rem;
        padding: 0.5rem 1rem;
        border: 1px dashed var(--border-color);
        color: var(--text-muted);
        text-align: center;
        font-size: 0.72rem;
        font-family: var(--font-mono);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: 0;
    }

    .advent-card {
        border-style: dashed !important;
    }

    /* ====================================
       7. Links カード — row-list
       ==================================== */
    .links-card {
        grid-column: 1 / -1;
    }

    .link-row-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .link-row {
        border-bottom: 1px solid var(--border-color);
    }

    .link-row:last-child {
        border-bottom: none;
    }

    .link-row-anchor {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.7rem 1.25rem;
        text-decoration: none;
        color: var(--text-main);
        transition: color 0.18s ease;
    }

    .link-row-prompt {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-muted);
        flex-shrink: 0;
        transition:
            color 0.18s ease,
            transform 0.22s ease;
    }

    .link-row-name {
        font-size: 0.88rem;
        font-weight: 600;
        font-family: var(--font-mono);
