                                <a
                                    href={TW_DAILY_URL}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="social-btn"
                                    aria-label="Twitter Daily"
                                >
                                    <Twitter size={14} /><span>Twitter</span>
                                </a>
                                <!-- <a
                                    href={TW_TECH_URL}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="social-btn"
                                    aria-label="Twitter Tech"
                                >
                                    <Twitter size={14} /><span>tech</span>
                                </a> -->
                            </div>
                            <p class="line line-blank" style="--i: 8"></p>
                            <p class="line" style="--i: 9">
                                <span class="prompt">$</span>
                                <a href="/about" class="cmd cmd-link">
                                    cd ./about<span class="cursor-arrow">
                                        →</span
                                    >
                                </a>
                            </p>
                        </div>
                    </div>

                    <!-- 右カラム: spec-list -->
                    <aside class="spec-block" style="--i: 2">
                        <p class="spec-block-title">// status</p>
                        <ul class="spec-list">
                            <li>
                                <span class="spec-key">name</span>
                                <span class="spec-val"
                                    >トラマト / 寅松 / toramutton</span
                                >
                            </li>
                            <li>
                                <span class="spec-key">univ</span>
                                <span class="spec-val">UEC25 Class A</span>
                            </li>
                            <li>
                                <span class="spec-key">UUID</span>
                                <span class="spec-val"
                                    >1b45a0db-7238-47e4-b95e-206522388c88</span
                                >
                            </li>
                            <li>
                                <span class="spec-key">stack</span>
                                <span class="spec-val">Rust / TS / C</span>
                            </li>
                            <li>
                                <span class="spec-key">status</span>
                                <span class="spec-val spec-val-live">
                                    <span class="dot-live"></span>online
                                </span>
                            </li>
                        </ul>
                    </aside>
                </div>
            </section>

            <section class="recent-posts">
                <div class="section-header">
