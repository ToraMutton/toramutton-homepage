---
export const prerender = true;
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import {
    SITE_TITLE,
    SITE_DESCRIPTION,
    TW_DAILY_URL,
    TW_TECH_URL,
    GITHUB_URL,
    NOTE_URL,
    ZENN_URL,
    QIITA_URL,
} from "../consts";
import { Image } from "astro:assets";
import heroImage from "../assets/toramutton.jpg";
import rssParser from "rss-parser";
import { fetchOgpImage } from "../utils/rss";
import {
    Twitter,
    Github,
    FileText,
    FileCode,
    GraduationCap,
    Milestone,
    ShieldCheck,
    Sparkles,
    Target,
    Cpu,
    Music,
    Users,
    Cake,
    PartyPopper,
    Wine,
    Timer,
    GitGraph,
    Rocket,
    ThermometerSun,
} from "lucide-astro";

// === RSSフィード取得 ===
const parser = new rssParser({
    customFields: {
        item: [
            ["media:thumbnail", "thumbnail"],
            ["enclosure", "enclosure"],
        ],
    },
});

const isDev = import.meta.env.DEV;

const getImageUrl = (item: any) => {
    // 1. media:thumbnail
    if (item.thumbnail) {
        return typeof item.thumbnail === "string"
            ? item.thumbnail
            : item.thumbnail.$?.url;
    }

    // 2. enclosure
    if (item.enclosure?.url) {
        return item.enclosure.url;
    }

    // 3. undefinedを返す
    return undefined;
};

interface UnifiedPost {
    title: string;
    url: string;
    date: Date;
    image?: string | any;
    source: "local" | "note" | "zenn" | "qiita";
}

// Local記事
const localPostsRaw = await getCollection("blog", ({ data }) => {
    return isDev || data.draft !== true;
});

const localPosts = localPostsRaw.map((post) => ({
    title: post.data.title,
    url: `/blog/${post.id}/`,
    date: post.data.pubDate,
    image: post.data.heroImage,
    tags: post.data.tags,
    source: "local" as const,
}));

// Note記事
let notePosts: UnifiedPost[] = [];
if (!isDev) {
    try {
        const noteFeed = await parser.parseURL(
            `https://note.com/toramutton/rss?t=${Date.now()}`,
        );
        notePosts = noteFeed.items.map((item: any) => ({
            title: item.title || "無題",
            url: item.link || "",
            date: new Date(item.pubDate || new Date()),
            image: getImageUrl(item),
            source: "note",
        }));
    } catch (e) {
        console.error("Note RSS fetch failed", e);
    }
}

// Zenn記事
let zennPosts: UnifiedPost[] = [];
if (!isDev) {
    try {
        const zennFeed = await parser.parseURL(
            `https://zenn.dev/toramutton/feed?t=${Date.now()}`,
        );
        zennPosts = zennFeed.items.map((item: any) => ({
            title: item.title || "無題",
            url: item.link || "",
            date: new Date(item.pubDate || new Date()),
            image: item.enclosure?.url,
            source: "zenn",
        }));
    } catch (e) {
        console.error("Zenn RSS fetch failed", e);
    }
}

// Qiita記事
let qiitaPosts: UnifiedPost[] = [];
if (!isDev) {
    try {
        const qiitaFeed = await parser.parseURL(
            `https://qiita.com/ToraMutton/feed?t=${Date.now()}`,
        );
        const qiitaItems = qiitaFeed.items.map(async (item: any) => {
            let imageUrl = item.enclosure?.url;
            if (!imageUrl && item.link) {
                imageUrl = await fetchOgpImage(item.link);
            }
            return {
                title: item.title || "無題",
                url: item.link || "",
                date: new Date(item.pubDate || new Date()),
                image: imageUrl,
                source: "qiita" as const,
            };
        });
        qiitaPosts = await Promise.all(qiitaItems);
    } catch (e) {
        console.error("Qiita RSS fetch failed", e);
    }
}

// 統合・ソート・抽出
const latestPosts = [...localPosts, ...notePosts, ...zennPosts, ...qiitaPosts]
    .sort((a, b) => b.date.valueOf() - a.date.valueOf())
    .slice(0, 5); // 最新記事、5選

// === GitHub Contributions取得 ===
type ContributionDay = { date: string; count: number; level: number };
let ghContributions: ContributionDay[] = [];
let ghTotal = 0;
try {
    const ghRes = await fetch(
        "https://github-contributions-api.jogruber.de/v4/toramutton?y=last",
    );
    const ghData = await ghRes.json();
    ghTotal = ghData.total?.lastYear || 0;
    ghContributions = ghData.contributions || [];
} catch (e) {
    console.error("GitHub contributions fetch failed", e);
}
// 直近13週分（91日）だけ表示
const recentContributions = ghContributions.slice(-91);

// === Countdown ===
const missions = [
    { title: "21歳の誕生日", date: "2027-06-20", icon: Cake },
    { title: "TOP4", date: "2026-07-04", icon: PartyPopper },
    { title: "夏休み", date: "2026-08-06", icon: ThermometerSun },
    { title: "米津玄師ライブ", date: "2026-11-12", icon: Music },
    { title: "2026年終了まで", date: "2026-12-31", icon: Milestone },
];

// === Mini Terminal ===
const terminalCommands = [
    { cmd: "whoami", out: "toramutton" },
    { cmd: "status", out: "studying" },
    { cmd: "mood", out: "creating something" },
    { cmd: "cat major", out: "CS @ UEC" },
    { cmd: "cat os", out: "Arch Linux / Windows 11" },
    { cmd: "echo $SHELL", out: "/bin/bash" },
    { cmd: "cat hobby", out: "Twitter / Anime / Music" },
    { cmd: "git status", out: "on branch: main" },
    { cmd: "pwd", out: "/home/toramutton" },
    { cmd: "echo $LANG", out: "ja_JP.UTF-8" },
    { cmd: "cat skills", out: "Rust / TypeScript / C" },
    { cmd: "cat editor", out: "Zed" },
    { cmd: "echo $WM", out: "Hyprland / GlazeWM" },
    { cmd: "cat focus", out: "web / compilers / LLM" },
    { cmd: "fortune", out: "多分動くと思うからリリースしようぜ" },
    { cmd: "cat music", out: "米津玄師 / Eve / ヨルシカ" },
    { cmd: "ping life", out: "64 bytes: icmp_seq=1 ttl=64" },
    { cmd: "cat dream", out: "living happy!" },
    { cmd: "cat gpa", out: "it's fine" },
    { cmd: "cat sleep", out: "insufficient" },
    { cmd: "git log --oneline", out: "abc1234 fix: everything" },
    { cmd: "cat arch", out: "I use Arch btw" },
    { cmd: "cat bugs", out: "feature" },
    { cmd: "sudo make me a sandwich", out: "Okay." },
    {
        cmd: "rm -rf laziness",
        out: "Permission denied: It's part of your identity",
    },
    { cmd: "cat motivation", out: "depends on the day" },
    { cmd: "uptime", out: "2 years at UEC" },
    { cmd: "ls projects", out: "too many" },
    { cmd: "man life", out: "No manual entry for life" },
    { cmd: "cat girlfriend", out: "404 Not Found" },
];

// ランダムで3つ選ぶ（重複なし）
const shuffled = [...terminalCommands].sort(() => Math.random() - 0.5);
const selectedCommands = shuffled.slice(0, 3);

const today = new Date();
const missionData = missions.map((m) => {
    const target = new Date(m.date);
    const diff = target.getTime() - today.getTime();
    const days = Math.ceil(diff / (1000 * 60 * 60 * 24));
    return { ...m, days };
});

interface FriendLink {
    name: string;
    url: string;
    description: string;
}

const friendLinks: FriendLink[] = [
    {
        name: "しおり🔖",
        url: "https://shiori-02-14.github.io/Homepage/index.html",
        description: "推し愛に溢れる最高のサイト",
    },
    {
        name: "柴犬被り",
        url: "https://memo.shibadogcap.com/",
        description: "クレーンゲームと自作キーボード熱血",
    },
    {
        name: "綿糸てせ",
        url: "https://ctes091x.net/",
        description: "PGP Keyが置いてあります",
    },
    {
        name: "ThunFasky",
        url: "https://thunfasky.com/",
        description: "PC構成の恩師であり、1クラのキチガイ担当",
    },
    {
        name: "こっとん",
        url: "https://cotton7.me/",
        description: "同じ.me派閥でうれしい",
    },
    {
        name: "yonu",
        url: "https://yonu.work/",
        description: "VSCodeリソース爆食い問題なんとかしていきましょう！",
    },
    {
        name: "Np",
        url: "https://negapainter.work/",
        description: "Switch改造大魔神",
    },
    {
        name: "ぽりとす",
        url: "https://polythos.net/",
        description: "目指せキリ番",
    },
    {
        name: "RM",
        url: "https://my-homepage-2qz3.vercel.app/",
        description: "武道強そう(小並感)",
    },
    {
        name: "ど　ら",
        url: "https://natamoko.jp/",
        description: "相互リンクやろうとしたら既にやってくれててびっくり",
    },
];
---

<!doctype html>
<html lang="ja">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header />
        <main>
            <section class="hero" data-hero>
                <div class="hero-grid">
                    <!-- 左カラム: terminal -->
                    <div class="terminal">
                        <div class="terminal-header">
                            <span class="terminal-dots">
                                <i
                                    data-dot="red"
                                    role="button"
                                    tabindex="0"
                                    aria-label="exit"></i>
                                <i
                                    data-dot="yellow"
                                    role="button"
                                    tabindex="0"
                                    aria-label="minimize"></i>
                                <i
                                    data-dot="green"
                                    role="button"
                                    tabindex="0"
                                    aria-label="maximize"></i>
