                                <span class="spec-key">focus</span>
                                <span class="spec-val"
                                    >Web · Systems · Compilers</span
                                >
                            </li>
                            <li>
                                <span class="spec-key">stack</span>
                                <span class="spec-val">Rust / TS / C</span>
                            </li>
