            <script>
            {
                function updateUptime() {
                    const now = new Date();
                    const birth = new Date('2006-06-20T00:00:00+09:00');
                    const site = new Date('2026-01-02T00:00:00+09:00');

                    const birthDays = Math.floor((now.getTime() - birth.getTime()) / (1000 * 60 * 60 * 24));
                    const siteDays = Math.floor((now.getTime() - site.getTime()) / (1000 * 60 * 60 * 24));

                    const birthEl = document.getElementById('uptime-birth');
                    const siteEl = document.getElementById('uptime-site');
                    const clockEl = document.getElementById('uptime-clock');

                    if (birthEl) birthEl.textContent = birthDays.toLocaleString();
                    if (siteEl) siteEl.textContent = siteDays.toLocaleString();
                    if (clockEl) {
                        clockEl.textContent = now.toLocaleString('ja-JP', {
                            timeZone: 'Asia/Tokyo',
                            hour: '2-digit',
                            minute: '2-digit',
                            second: '2-digit',
                        });
                    }
                }

                updateUptime();
                setInterval(updateUptime, 1000);
            }
