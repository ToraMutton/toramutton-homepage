                                    <Cake size={14} class="uptime-icon" /> 生まれてから
                                </div>
                                <div class="uptime-value">
                                    <span class="uptime-num" id="uptime-birth"
                                        >--</span
                                    >
                                    <span class="uptime-unit">days</span>
                                </div>
                                <div class="uptime-date">since 2006/06/20</div>
                            </div>
                            <div class="uptime-item">
                                <div class="uptime-label">
                                    <Rocket size={14} class="uptime-icon" /> このサイトができてから
                                </div>
                                <div class="uptime-value">
                                    <span class="uptime-num" id="uptime-site"
                                        >--</span
                                    >
                                    <span class="uptime-unit">days</span>
                                </div>
                                <div class="uptime-date">since 2026/01/02</div>
                            </div>
                        </div>
                        <div class="uptime-clock" id="uptime-clock"></div>
                    </div>
                </div>

                <!-- Advent 2026 -->
                <div class="widget-card advent-card" data-reveal>
                    <div class="card-header">
                        <Sparkles class="icon-blue" size={16} />
                        <h3>Advent 2026</h3>
                    </div>
                    <div class="card-body">
                        <p class="card-desc">
                            一人アドベントカレンダー2026開催予定地
                        </p>
                        <div class="coming-soon-badge">Coming soon...</div>
                    </div>
                </div>

                <!-- Links -->
                <div class="widget-card links-card" data-reveal>
                    <div class="card-header">
                        <Users class="icon-secondary" size={16} />
                        <h3>Links</h3>
                    </div>
                    <div class="link-list">
                        {
                            friendLinks.map((link) => (
                                <a
                                    href={link.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="link-item"
                                >
                                    <span class="link-name">
                                        {link.name}
                                        <span class="external-icon">↗</span>
                                    </span>
                                    <span class="link-desc">
                                        {link.description}
                                    </span>
                                </a>
                            ))
                        }
                    </div>
                </div>
            </div>

            <!-- Today's Music -->
            <div class="widget-card recommendation-card" data-reveal>
                <div class="card-header">
                    <Music class="icon-secondary" size={16} />
                    <h3>Today's Music</h3>
                </div>
                <div id="song-display" class="song-container">
                    <p class="song-title" id="song-title">Loading...</p>
                    <p class="song-year-wrapper">
                        released in <span id="song-year" class="song-year"
                            >----</span
                        >
                    </p>
                </div>
                <button id="next-song-btn" class="secondary-btn">
                    reload →
                </button>
            </div>

            <script>
                import { songs } from "../data/songs";

                document.addEventListener("astro:page-load", () => {
                    const hero =
                        document.querySelector<HTMLElement>("[data-hero]");
                    if (hero) {
                        const trigger = () =>
                            requestAnimationFrame(() =>
                                hero.setAttribute("data-loaded", ""),
                            );
                        document.fonts?.ready
                            ? document.fonts.ready.then(trigger)
                            : trigger();
                    }

                    // ---- Terminal dots easter egg ----
                    const terminal =
                        document.querySelector<HTMLElement>(".terminal");
                    const termBody =
                        terminal?.querySelector<HTMLElement>(".terminal-body");

                    terminal
                        ?.querySelectorAll<HTMLElement>("i[data-dot]")
                        .forEach((dot) => {
                            dot.addEventListener("click", () => {
                                if (terminal.classList.contains("is-busy"))
                                    return;
                                const kind = dot.dataset.dot;
                                if (kind === "red")
                                    exitDot(terminal, termBody!);
                                if (kind === "yellow") minimizeDot(terminal);
                                if (kind === "green") maxDot(termBody!);
                            });
                        });

                    function exitDot(
                        terminal: HTMLElement,
                        termBody: HTMLElement,
                    ) {
                        terminal.classList.add("is-busy");
                        const saved = termBody.innerHTML;

                        // exit 0 を追記
                        const exitLine = document.createElement("p");
                        exitLine.className = "line";
                        exitLine.innerHTML = `<span class="prompt">$</span><span class="cmd"> exit 0</span>`;
                        termBody.appendChild(exitLine);

                        // フェードアウト → reboot メッセージ → 復元
                        setTimeout(() => {
                            termBody.style.cssText =
                                "opacity:0; transition:opacity 0.3s ease";
                            setTimeout(() => {
                                termBody.innerHTML = `
                <p class="line"><span class="comment"># Connection closed.</span></p>
                <p class="line"><span class="comment"># Rebooting...</span></p>
            `;
                                termBody.style.cssText =
                                    "opacity:1; transition:opacity 0.3s ease";
                                setTimeout(() => {
                                    termBody.style.cssText =
                                        "opacity:0; transition:opacity 0.3s ease";
                                    setTimeout(() => {
                                        termBody.innerHTML = saved;
                                        termBody.style.cssText = "";
                                        terminal.classList.remove("is-busy");
                                        // 再アニメーション: data-loaded を一瞬外して付け直す
                                        const hero =
                                            document.querySelector(
                                                "[data-hero]",
                                            );
                                        hero?.removeAttribute("data-loaded");
                                        requestAnimationFrame(() =>
                                            hero?.setAttribute(
                                                "data-loaded",
                                                "",
                                            ),
                                        );
                                    }, 320);
                                }, 1200);
                            }, 350);
                        }, 600);
                    }

                    function minimizeDot(terminal: HTMLElement) {
                        terminal.classList.add("is-minimizing", "is-busy");
                        setTimeout(() => {
                            terminal.classList.remove("is-minimizing");
                            setTimeout(
                                () => terminal.classList.remove("is-busy"),
                                350,
                            );
                        }, 580);
                    }

                    function maxDot(termBody: HTMLElement) {
                        const msg = document.createElement("p");
                        msg.className = "line line-comment";
                        msg.innerHTML = `<span class="comment"># nothing to maximize here :)</span>`;
                        termBody.appendChild(msg);
                        setTimeout(() => {
                            msg.style.cssText =
                                "opacity:0; transition:opacity 0.3s ease";
                            setTimeout(() => msg.remove(), 320);
                        }, 1500);
                    }

                    // カウントダウン処理
                    const missionItems =
                        document.querySelectorAll<HTMLElement>(
                            ".js-mission-item",
                        );

                    // 今日の日付
                    const now = new Date();
                    now.setHours(0, 0, 0, 0);

                    missionItems.forEach((item) => {
                        const targetDateStr = item.dataset.date;
                        if (!targetDateStr) return;

                        const target = new Date(targetDateStr);
                        target.setHours(0, 0, 0, 0);

                        const diff = target.getTime() - now.getTime();
                        const days = Math.ceil(diff / (1000 * 60 * 60 * 24));

                        const numEl =
                            item.querySelector<HTMLElement>(".js-days-num");
                        if (numEl) {
                            numEl.innerText = days.toString();
                        }
                    });

                    const titleEl = document.getElementById("song-title");
                    const yearEl = document.getElementById("song-year");
                    const btn = document.getElementById("next-song-btn");

                    // ---- marquee: カードを複製して無限ループ ----
                    const track = document.getElementById("marquee-track");
                    if (track) {
                        const original = track.innerHTML;
                        track.innerHTML = original + original; // 2セット並べる
                    }

                    // ---- widget-card stagger reveal (IntersectionObserver) ----
                    const revealCards =
                        document.querySelectorAll<HTMLElement>("[data-reveal]");
                    const revealObserver = new IntersectionObserver(
                        (entries) => {
                            entries.forEach((entry) => {
                                if (entry.isIntersecting) {
                                    const el = entry.target as HTMLElement;
                                    const delay = el.dataset.revealDelay ?? "0";
                                    el.style.transitionDelay = `${delay}ms`;
                                    el.classList.add("is-visible");
                                    revealObserver.unobserve(el);
                                }
                            });
                        },
                        { threshold: 0.12 },
                    );

                    // grid-container 内は stagger (80ms ずつ)
                    document
                        .querySelectorAll<HTMLElement>(
                            ".grid-container [data-reveal]",
                        )
                        .forEach((el, i) => {
                            el.dataset.revealDelay = String(i * 80);
                            revealObserver.observe(el);
                        });

                    // recommendation-card は単独
                    document
                        .querySelectorAll<HTMLElement>(
                            ".recommendation-card[data-reveal]",
                        )
                        .forEach((el) => revealObserver.observe(el));

                    function updateSong() {
                        if (!titleEl || !yearEl) return;
                        const randomSong =
                            songs[Math.floor(Math.random() * songs.length)];

                        // ワイプをリセット → 次フレームで再発火
                        titleEl.classList.remove("song-wipe");
                        void titleEl.offsetWidth; // reflow
                        titleEl.textContent = randomSong.title;
                        yearEl.textContent = randomSong.year;
                        requestAnimationFrame(() => {
                            titleEl.classList.add("song-wipe");
                        });
                    }

                    btn?.addEventListener("click", updateSong);
                    updateSong();
                });

                // メッセージ
                const style3D = `
                font-weight: 900;
                font-size: 2.5rem;
                color: #bae6fd;
                text-shadow: 
                    0 1px 0 #0ea5e9,
                    0 2px 0 #0284c7,
                    0 3px 0 #0369a1,
                    0 4px 0 #075985,
                    0 5px 0 #0c4a6e,
                    0 6px 1px rgba(0,0,0,0.1),
                    0 0 5px rgba(0,0,0,0.1),
                    0 1px 3px rgba(0,0,0,0.3),
                    0 3px 5px rgba(0,0,0,0.2),
                    0 5px 10px rgba(0,0,0,0.25),
                    0 10px 10px rgba(0,0,0,0.2),
                    0 20px 20px rgba(0,0,0,0.15);
            `;

                // AA用のスタイル
                const styleAA =
                    "font-family: 'Menlo', 'Consolas', monospace; font-weight: bold; color: #38bdf8; line-height: 1.2;";
                const styleBody =
                    "font-family: sans-serif; color: #7dd3fc; font-size: 0.9rem;";

                // 1. 立体ロゴ
                console.log("%cToraMutton's Homepage", style3D);

                // 2. 巨大アスキーアート
                // ⚠️ 整形するな！整形するな！
                console.log(
                    `%c
  ______                 __  ___      __  __            
 /_  __/___  ________ _ /  |/  /_  __/ /_/ /_____  ____ 
  / / / __ \\/ ___/ __ \`/ /|_/ / / / / __/ __/ __ \\/ __ \\
 / / / /_/ / /  / /_/ / /  / / /_/ / /_/ /_/ /_/ / / / /
/_/  \\____/_/   \\__,_/_/  /_/\\__,_/\\__/\\__/\\____/_/ /_/ 
            `,
                    styleAA,
                );

                // 3. メッセージ
                console.log(
                    `%c
        🚀 Built with Astro & Vercel.
        -----------------------------------
        Looking for bugs?
        Thanks for visiting!
            `,
                    styleBody,
                );
            </script>

            <!-- Uptime counter script -->
            <script>
                {
                    function updateUptime() {
                        const now = new Date();
                        const birth = new Date("2006-06-20T00:00:00+09:00");
                        const site = new Date("2026-01-02T00:00:00+09:00");

                        const birthDays = Math.floor(
                            (now.getTime() - birth.getTime()) /
                                (1000 * 60 * 60 * 24),
                        );
                        const siteDays = Math.floor(
                            (now.getTime() - site.getTime()) /
                                (1000 * 60 * 60 * 24),
                        );

                        const birthEl = document.getElementById("uptime-birth");
                        const siteEl = document.getElementById("uptime-site");
                        const clockEl = document.getElementById("uptime-clock");

                        if (birthEl)
                            birthEl.textContent = birthDays.toLocaleString();
                        if (siteEl)
                            siteEl.textContent = siteDays.toLocaleString();
                        if (clockEl) {
                            clockEl.textContent = now.toLocaleString("ja-JP", {
                                timeZone: "Asia/Tokyo",
                                hour: "2-digit",
                                minute: "2-digit",
                                second: "2-digit",
                            });
                        }
                    }

                    updateUptime();
                    setInterval(updateUptime, 1000);
                }
            </script>
        </main>
        <Footer />
    </body>
</html>

<style>
