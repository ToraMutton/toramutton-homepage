---
export const prerender = true;
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

import homepageImage from "../assets/works/toramutton.webp";
import vextraImage from "../assets/works/vextra.webp";
import artoramImage from "../assets/works/artoram.webp";
import nexusImage from "../assets/works/nexus.webp";

import {
    ExternalLink,
    Github,
    Code2,
    Gamepad2,
    Shapes,
    Cpu,
    Keyboard,
    BarChart3,
    CheckCircle2,
    Hammer,
    Lightbulb,
    Terminal,
    Grid3X3,
    Grid,
} from "lucide-astro";

interface Work {
    name: string;
    description: string;
    url?: string;
    github?: string;
    tags: string[];
    icon: any;
    year: string;
    status: "completed" | "in-progress" | "planned";
    image?: ImageMetadata;
}

const works: Work[] = [
    {
        name: "ToraMutton's Homepage",
        description:
            "Astro + Vercelで構築した個人用ポートフォリオサイト。GitHub Actionsを用いたZenn/Qiita記事のRSS自動取得・自作ビルドパイプライン付き。",
        url: "https://toramutton.me",
        github: "https://github.com/ToraMutton/toramutton-homepage",
        tags: ["Astro", "TypeScript", "Vercel", "GitHub Actions"],
        icon: Code2,
        year: "2026",
        status: "completed",
        image: homepageImage,
    },
    {
        name: "Minecraft Skin Editor",
        description:
            "ブラウザ上で完結するMinecraftスキンエディター。Three.jsによるリアルタイム3Dプレビューとピクセル単位のペイント機能、オートセーブ機能付き。",
        tags: ["TypeScript", "Three.js", "React"],
        icon: Gamepad2,
        year: "2026",
        url: "https://vextra.toramutton.me/",
        github: "https://github.com/ToraMutton/minecraft-skin-editor",
        status: "completed",
        image: vextraImage,
    },
    {
        name: "Artoram",
        description:
            "Canvas APIを使った幾何学アートジェネレーター。数式のパラメータをリアルタイムで操作し、生成された画像をエクスポートできるWebツール。",
        tags: ["TypeScript", "Canvas API", "React"],
        icon: Shapes,
        year: "2026",
        url: "https://artoram.toramutton.me",
        github: "https://github.com/ToraMutton/artoram",
        status: "completed",
        image: artoramImage,
    },
    {
        name: "NEXUS for UEC",
        description:
            "電通大生向け時間割アプリ。チームbookmarkの一員として頑張っております。電通大生全員インストールして",
        tags: ["Swift", "Kotlin", "Firebase"],
        icon: Grid3X3,
        year: "2026",
        url: "https://nexusforuec.team-bookmark.com/",
        github: "https://github.com/shiori-02-14/NEXUS-",
        status: "completed",
        image: nexusImage,
    },
    {
        name: "ローカルLLM",
        description:
            "自作PCの AMD Radeon RX 9060 XT 16GB と ROCm を活用した、完全ローカルな推論環境の構築プロジェクト。",
        tags: ["Python", "ROCm", "LLM"],
        icon: Cpu,
        year: "2026",
        status: "in-progress",
    },
    {
        name: "ネタプログラミング言語",
        description:
            "Go言語による自作プログラミング言語の開発。字句解析・構文解析といった言語処理系の仕組みを学ぶための、実用性皆無なネタ言語。",
        tags: ["Go", "Compiler", ".trmt"],
        icon: Terminal,
        year: "2027予定",
        status: "planned",
    },
];

const completedWorks = works.filter((w) => w.status === "completed");
const inProgressWorks = works.filter((w) => w.status === "in-progress");
const plannedWorks = works.filter((w) => w.status === "planned");
---

<!doctype html>
<html lang="ja">
    <head>
        <BaseHead title={`${SITE_TITLE} | Works`} description="制作物一覧" />
    </head>
    <body>
        <Header />
        <main>
            <section class="works-section">
                <h1 class="works-title">Works</h1>
                <p class="works-desc">
                    制作した・現在進行中・予定のプロジェクト
                </p>

                {
                    completedWorks.length > 0 && (
                        <>
                            <h2 class="section-heading">
                                <CheckCircle2
                                    size={20}
                                    class="section-icon completed-icon"
                                />
                                Completed
                            </h2>
                            <ul class="works-list">
                                {completedWorks.map((work) => (
                                    <li class="work-row">
                                        {work.image && (
                                            <div class="work-image-layer">
                                                <Image
                                                    src={work.image}
                                                    alt=""
                                                    loading="lazy"
                                                />
                                            </div>
                                        )}
                                        <span class="work-icon-cell">
                                            <work.icon size={20} />
                                        </span>
                                        <div class="work-main">
                                            <span class="work-name">
                                                {work.name}
                                            </span>
                                            <div class="work-tags">
                                                {work.tags.map((tag) => (
                                                    <span class="work-tag">
                                                        {tag}
                                                    </span>
                                                ))}
                                            </div>
                                        </div>
                                        <p class="work-desc-text">
                                            {work.description}
                                        </p>
                                        <div class="work-right">
                                            <span class="work-year">
                                                {work.year}
                                            </span>
                                            <div class="work-links">
                                                {work.url && (
                                                    <a
                                                        href={work.url}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        class="work-link"
                                                        aria-label="Visit site"
                                                    >
                                                        <ExternalLink
                                                            size={16}
                                                        />
                                                    </a>
                                                )}
                                                {work.github && (
                                                    <a
                                                        href={work.github}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        class="work-link"
                                                        aria-label="GitHub repository"
                                                    >
                                                        <Github size={16} />
                                                    </a>
                                                )}
                                            </div>
                                        </div>
                                    </li>
                                ))}
                            </ul>
                        </>
                    )
                }

                {
                    inProgressWorks.length > 0 && (
                        <>
                            <h2 class="section-heading">
                                <Hammer
                                    size={20}
                                    class="section-icon progress-icon"
                                />
                                In Progress
                            </h2>
                            <ul class="works-list">
                                {inProgressWorks.map((work) => (
                                    <li class="work-row in-progress">
                                        <span class="work-icon-cell">
                                            <work.icon size={20} />
                                        </span>
                                        <div class="work-main">
                                            <span class="work-name">
                                                {work.name}
                                            </span>
                                            <div class="work-tags">
                                                {work.tags.map((tag) => (
                                                    <span class="work-tag">
                                                        {tag}
                                                    </span>
                                                ))}
                                            </div>
                                        </div>
                                        <p class="work-desc-text">
                                            {work.description}
                                        </p>
                                        <div class="work-right">
                                            <span class="work-year">
                                                {work.year}
                                            </span>
                                            <div class="work-links">
                                                {work.github && (
                                                    <a
                                                        href={work.github}
                                                        target="_blank"
                                                        rel="noopener noreferrer"
                                                        class="work-link"
                                                        aria-label="GitHub repository"
                                                    >
                                                        <Github size={16} />
                                                    </a>
                                                )}
                                            </div>
                                        </div>
                                    </li>
                                ))}
                            </ul>
                        </>
                    )
                }

                {
                    plannedWorks.length > 0 && (
                        <>
                            <h2 class="section-heading">
                                <Lightbulb
                                    size={20}
                                    class="section-icon planned-icon"
                                />
                                Planned
                            </h2>
                            <ul class="works-list">
                                {plannedWorks.map((work) => (
                                    <li class="work-row planned">
                                        <span class="work-icon-cell">
                                            <work.icon size={20} />
                                        </span>
                                        <div class="work-main">
                                            <span class="work-name">
                                                {work.name}
                                            </span>
                                            <div class="work-tags">
                                                {work.tags.map((tag) => (
                                                    <span class="work-tag">
                                                        {tag}
                                                    </span>
                                                ))}
                                            </div>
                                        </div>
                                        <p class="work-desc-text">
                                            {work.description}
                                        </p>
                                        <div class="work-right">
                                            <span class="work-year">
                                                {work.year}
                                            </span>
                                        </div>
                                    </li>
                                ))}
                            </ul>
                        </>
                    )
                }
            </section>
        </main>
        <Footer />
    </body>
</html>

<style>
    main {
        max-width: 900px;
        margin: 0 auto;
        padding: 6rem 1.5rem 3rem;
    }

    /* =========================================
       1. ヘッダ部
       ========================================= */
    .works-title {
        font-size: 2rem;
        margin: 0 0 0.5rem;
        color: var(--text-main);
        font-family: var(--font-mono, "JetBrains Mono", monospace);
        letter-spacing: -0.02em;
    }

    .works-desc {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 2.5rem;
    }

    /* =========================================
       2. セクション見出し
       ========================================= */
    .section-heading {
        font-size: 1.1rem;
        margin: 2.5rem 0 0.5rem;
        color: var(--text-main);
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-family: var(--font-mono, "JetBrains Mono", monospace);
        font-weight: 700;
        letter-spacing: 0.02em;
        border: none !important;
        padding-bottom: 0 !important;
    }

    /* global.cssのh2::afterを上書き */
    .section-heading::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border-color);
        margin-left: 0.5rem;
        position: static;
        width: auto;
        bottom: auto;
        left: auto;
        transition: none;
    }

    .section-icon {
        flex-shrink: 0;
    }

    .completed-icon {
        color: #22c55e;
    }

    .progress-icon {
        color: var(--accent-blue);
    }

    .planned-icon {
        color: var(--text-muted);
    }

    /* =========================================
       3. Row list
       ========================================= */
    .works-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    .work-row {
        display: grid;
        grid-template-columns: 2rem 1fr 2fr auto;
        gap: 1.5rem;
        align-items: center;
        padding: 1rem 0 1rem 0.75rem;
        border-bottom: 1px solid var(--border-color);
        border-radius: 0;
        position: relative;
        overflow: hidden;
        transition:
            background-color 0.2s ease,
            border-bottom-color 0.2s ease;
    }

    /* hover対応デバイスのみ */
    @media (hover: hover) {
        .work-row:hover {
            background-color: rgba(34, 211, 238, 0.04);
            border-bottom-color: var(--accent-blue);
        }
    }

    /* =========================================
       4. 各セル
       ========================================= */
    .work-icon-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
    }

    .work-main {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        min-width: 0;
    }

    .work-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1.3;
        font-family: var(--font-mono, "JetBrains Mono", monospace);
        word-break: break-word;
        position: relative;
        padding-left: 0;
        transition:
            padding-left 0.25s ease,
            color 0.2s ease;
    }

    .work-name::before {
        content: "▸";
        position: absolute;
        left: 0;
        top: 50%;
        transform: translate(-0.5rem, -50%);
        color: var(--accent-blue);
        opacity: 0;
        transition:
            opacity 0.25s ease,
            transform 0.25s ease;
        font-family: var(--font-mono, "JetBrains Mono", monospace);
    }

    @media (hover: hover) {
        .work-row:hover .work-name {
            padding-left: 1rem;
            color: var(--accent-blue);
        }
        .work-row:hover .work-name::before {
            opacity: 1;
            transform: translate(0, -50%);
        }
    }

    .work-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
    }

    .work-tag {
        font-family: var(--font-mono, "JetBrains Mono", monospace);
        font-size: 0.7rem;
        border: 1px solid var(--border-color);
        border-radius: 0;
        padding: 0.1em 0.4em;
        color: var(--text-muted);
        background: transparent;
        font-weight: 500;
    }

    .work-desc-text {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin: 0;
    }

    .work-right {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        flex-shrink: 0;
    }

    .work-year {
        font-family: var(--font-mono, "JetBrains Mono", monospace);
        color: var(--text-muted);
        font-size: 0.8rem;
        white-space: nowrap;
    }

    .work-links {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .work-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
        text-decoration: none;
        padding: 0.25rem;
        border: none;
        background: transparent;
        border-radius: 0;
        transition: color 0.2s ease;
    }

    @media (hover: hover) {
        .work-link:hover {
            color: var(--accent-blue);
        }
    }

    /* =========================================
   5. ステータス別装飾 & 画像レイヤー
   ========================================= */

    /* planned：rowごと薄く */
    .work-row.planned {
        opacity: 0.5;
    }

    /* 画像レイヤー */
    .work-image-layer {
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 45%;
        z-index: 0;
        pointer-events: none;
        clip-path: polygon(15% 0, 100% 0, 100% 100%, 0 100%);
        -webkit-mask-image: linear-gradient(
            to left,
            black 0%,
            black 30%,
            transparent 100%
        );
        mask-image: linear-gradient(
            to left,
            black 0%,
            black 30%,
            transparent 100%
        );
        opacity: 0.35;
        transition: opacity 0.3s ease;
    }

    .work-image-layer img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .work-image-layer::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--background);
    opacity: 0;
    transition: opacity 0.3s ease;
}

    @media (hover: hover) {
        .work-row:hover .work-image-layer::after {
            opacity: 0.5;  /* ホバー時に暗いオーバーレイが乗る */
        }
    }

    /* テキスト要素を画像より前面に */
    .work-icon-cell,
    .work-main,
    .work-desc-text,
    .work-right {
        position: relative;
        z-index: 1;
    }

    /* タグの背景（画像と重なったとき読みやすくする） */
    .work-tag {
        background: var(--background);
    }

    /* =========================================
       6. モバイル対応
       ========================================= */
    @media (max-width: 720px) {
        main {
            padding: 5rem 1rem 2rem;
        }

        .work-row {
            grid-template-columns: 2rem 1fr auto;
            grid-template-rows: auto auto;
            gap: 0.5rem 1rem;
            padding: 1rem 0;
        }

        .work-icon-cell {
            grid-row: 1;
            grid-column: 1;
        }

        .work-main {
            grid-row: 1;
            grid-column: 2;
        }

        .work-right {
            grid-row: 1;
            grid-column: 3;
        }

        .work-desc-text {
            grid-row: 2;
            grid-column: 1 / -1;
            font-size: 0.8rem;
            padding-left: 0;
        }

        .work-name {
            font-size: 0.9rem;
        }
</style>
