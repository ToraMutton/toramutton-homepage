---
export const prerender = true;
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
import { ExternalLink, Github, Code2, Gamepad2, Shapes, Cpu, Keyboard, BarChart3, CheckCircle2, Hammer, Lightbulb, Terminal } from 'lucide-astro';

interface Work {
    name: string;
    description: string;
    url?: string;
    github?: string;
    tags: string[];
    icon: any;
    year: string;
    status: 'completed' | 'in-progress' | 'planned';
}

const works: Work[] = [
    {
        name: "ToraMutton's Homepage",
        description: "Astro + Vercelで構築した個人用ポートフォリオサイト。ダークモード対応や、GitHub Actionsを用いたZenn/Qiita記事のRSS自動取得・ビルドパイプラインを自作して組み込んでいます。",
        url: "https://toramutton.me",
        github: "https://github.com/ToraMutton/toramutton-homepage",
        tags: ["Astro", "TypeScript", "Vercel", "GitHub Actions"],
        icon: Code2,
        year: "2026",
        status: 'completed',
    },
    {
        name: "Minecraft Skin Editor",
        description: "ブラウザ上で完結するMinecraftスキンエディター。Three.jsによるリアルタイム3Dプレビューとピクセル単位のペイント機能、オートセーブ機能付き！。",
        tags: ["TypeScript", "Three.js", "React"],
        icon: Gamepad2,
        year: "2026春予定",
        github: "https://github.com/ToraMutton/minecraft-skin-editor",
        status: 'completed',
    },
    {
        name: "Artoram",
        description: "Canvas APIを使った幾何学アートジェネレーター。数式のパラメータをリアルタイムで操作し、生成された画像をエクスポートできるWebツールです。",
        tags: ["TypeScript", "Canvas API", "React"],
        icon: Shapes,
        year: "2026",
        url: "https://artoram.toramutton.me",
        github: "https://github.com/ToraMutton/artoram",
        status: 'completed',
    },
    {
        name: "ローカルLLM環境",
        description: "自作PCの AMD Radeon RX 9060 XT 16GB と ROCm を活用した、完全ローカルな推論環境の構築プロジェクト。",
        tags: ["Python", "ROCm", "LLM"],
        icon: Cpu,
        year: "2026夏〜秋予定",
        status: 'planned',
    },
    // {
    //     name: "タイピングゲーム",
    //     description: "日英対応のタイピング練習アプリ。Web Audio APIを活用した心地よい打鍵音と、WPM計測・ランキング機能を備えた実践的なツール。",
    //     tags: ["TypeScript", "Web Audio API"],
    //     icon: Keyboard,
    //     year: "2026予定",
    //     status: 'planned',
    // },
    // {
    //     name: "アルゴリズム可視化ツール",
    //     description: "ソートや探索などの基礎的なアルゴリズムの挙動をアニメーションで可視化。計算機科学の学習補助を目的としたステップ実行ツール。",
    //     tags: ["TypeScript", "Canvas API", "Algorithm"],
    //     icon: BarChart3,
    //     year: "2026予定",
    //     status: 'planned',
    // },
    {
        name: "オリジナルプログラミング言語",
        description: "Go言語による自作プログラミング言語の開発。字句解析・構文解析といった言語処理系の仕組みを学ぶための、実用性皆無なオリジナル言語。",
        tags: ["Go", "Compiler", ".trmt"],
        icon: Terminal,
        year: "2027予定",
        status: 'planned',
    },
];
const completedWorks = works.filter(w => w.status === 'completed');
const inProgressWorks = works.filter(w => w.status === 'in-progress');
const plannedWorks = works.filter(w => w.status === 'planned');
---

<!doctype html>
<html lang="ja">
    <head>
        <BaseHead title={`${SITE_TITLE} | Works`} description="トラマトの制作物一覧" />
    </head>
    <body>
        <Header />
        <main>
            <section class="works-section">
                <h1 class="works-title">Works</h1>
                <p class="works-desc">制作した・現在進行中・予定のプロジェクト</p>

                {completedWorks.length > 0 && (
                    <>
                        <h2 class="section-heading">
                            <CheckCircle2 size={20} class="section-icon completed-icon" />
                            Completed
                        </h2>
                        <div class="works-grid">
                            {completedWorks.map((work) => (
                                <div class="work-card glass-card">
                                    <div class="work-header">
                                        <work.icon class="work-icon" size={24} />
                                        <div class="work-meta">
                                            <h3 class="work-name">{work.name}</h3>
                                            <span class="work-year">{work.year}</span>
                                        </div>
                                    </div>
                                    <p class="work-description">{work.description}</p>
                                    <div class="work-tags">
                                        {work.tags.map((tag) => <span class="work-tag">{tag}</span>)}
                                    </div>
                                    <div class="work-links">
                                        {work.url && (
                                            <a href={work.url} target="_blank" rel="noopener noreferrer" class="work-link">
                                                <ExternalLink size={14} /> Visit
                                            </a>
                                        )}
                                        {work.github && (
                                            <a href={work.github} target="_blank" rel="noopener noreferrer" class="work-link github-link">
                                                <Github size={14} /> Source
                                            </a>
                                        )}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </>
                )}

                {inProgressWorks.length > 0 && (
                    <>
                        <h2 class="section-heading">
                            <Hammer size={20} class="section-icon progress-icon" />
                            In Progress
                        </h2>
                        <div class="works-grid">
                            {inProgressWorks.map((work) => (
                                <div class="work-card glass-card in-progress">
                                    <div class="work-header">
                                        <work.icon class="work-icon" size={24} />
                                        <div class="work-meta">
                                            <h3 class="work-name">{work.name}</h3>
                                            <span class="work-year">{work.year}</span>
                                        </div>
                                    </div>
                                    <p class="work-description">{work.description}</p>
                                    <div class="work-tags">
                                        {work.tags.map((tag) => <span class="work-tag">{tag}</span>)}
                                    </div>
                                    <div class="work-links">
                                        {work.github && (
                                            <a href={work.github} target="_blank" rel="noopener noreferrer" class="work-link github-link">
                                                <Github size={14} /> Repository
                                            </a>
                                        )}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </>
                )}

                {plannedWorks.length > 0 && (
                    <>
                        <h2 class="section-heading">
                            <Lightbulb size={20} class="section-icon planned-icon" />
                            Planned
                        </h2>
                        <div class="works-grid">
                            {plannedWorks.map((work) => (
                                <div class="work-card glass-card planned">
                                    <div class="work-header">
                                        <work.icon class="work-icon" size={24} />
                                        <div class="work-meta">
                                            <h3 class="work-name">{work.name}</h3>
                                            <span class="work-year">{work.year}</span>
                                        </div>
                                    </div>
                                    <p class="work-description">{work.description}</p>
                                    <div class="work-tags">
                                        {work.tags.map((tag) => <span class="work-tag">{tag}</span>)}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </>
                )}
            </section>
        </main>
        <Footer />
    </body>
</html>

<style>
    main {
        max-width: 900px;
        margin: 0 auto;
        padding: 6rem 1.5rem 3rem;
    }

    .works-title {
        font-size: 2rem;
        margin: 0 0 0.5rem;
        color: var(--text-main);
    }

    .works-desc {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 2rem;
    }

    .section-heading {
        font-size: 1.4rem;
        margin: 2.5rem 0 1.2rem;
        color: var(--text-main);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .section-heading::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border-color);
        margin-left: 0.5rem;
    }

    .section-icon {
        flex-shrink: 0;
    }

    .completed-icon {
        color: #22c55e;
    }

    .progress-icon {
        color: var(--accent-blue);
    }

    .planned-icon {
        color: var(--text-muted);
    }

    .works-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
        gap: 1.5rem;
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        padding: 1.8rem;
        border-radius: 16px;
        border: 1px solid var(--border-color);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    :global(html.dark) .glass-card {
        background: rgba(255, 255, 255, 0.03);
        border-color: rgba(255, 255, 255, 0.1);
    }

    .glass-card.in-progress {
        border-left: 3px solid var(--accent-blue);
    }

    .glass-card.planned {
        opacity: 0.6;
        border-style: dashed;
    }

    .glass-card.planned:hover {
        opacity: 0.9;
    }

    .glass-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.12);
        border-color: var(--accent-blue);
    }

    .work-header {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .work-icon {
        color: var(--accent-blue);
        flex-shrink: 0;
    }

    .work-meta {
        display: flex;
        align-items: baseline;
        gap: 0.8rem;
        flex: 1;
    }

    .work-name {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-main);
        line-height: 1.3;
    }

    .work-year {
        font-family: "JetBrains Mono", monospace;
        font-size: 0.75rem;
        color: var(--accent-blue);
        font-weight: 700;
        flex-shrink: 0;
    }

    .work-description {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.7;
        margin: 0;
    }

    .work-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .work-tag {
        font-size: 0.7rem;
        padding: 0.2rem 0.6rem;
        border-radius: 99px;
        background: rgba(59, 130, 246, 0.1);
        color: var(--accent-blue);
        border: 1px solid rgba(59, 130, 246, 0.2);
        font-family: "JetBrains Mono", monospace;
        font-weight: 600;
    }

    .work-links {
        display: flex;
        gap: 0.8rem;
        margin-top: auto;
        padding-top: 0.5rem;
    }

    .work-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-main);
        background: transparent;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .work-link:hover {
        border-color: var(--accent-blue);
        color: var(--accent-blue);
        background: rgba(56, 189, 248, 0.05);
        transform: translateY(-1px);
    }

    .github-link:hover {
        border-color: #333;
        color: #333;
        background: rgba(0, 0, 0, 0.03);
    }

    :global(html.dark) .github-link:hover {
        border-color: #fff;
        color: #fff;
        background: rgba(255, 255, 255, 0.05);
    }

    @media (max-width: 600px) {
        main {
            padding: 5rem 1rem 2rem;
        }

        .works-grid {
            grid-template-columns: 1fr;
        }

        .work-meta {
            flex-direction: column;
            gap: 0.2rem;
        }
    }
</style>
